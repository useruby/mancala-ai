#!/usr/bin/env python3
"""Launch a one-off RunPod experiment bundle."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[2]
sys.path.insert(0, str(REPO_ROOT))

from ml.alphazero_lite.runpod_experiment import (  # noqa: E402
    build_dry_run_plan,
    orchestrate,
)

DEFAULT_BUNDLE_PATH = str(REPO_ROOT / "tmp" / "runpod_experiment_bundle.tar.gz")
DEFAULT_LOCAL_RESULTS_PATH = str(REPO_ROOT / "tmp" / "runpod_results")

parser = argparse.ArgumentParser(
    prog="script/ai/runpod_experiment",
    description="Launch a one-off RunPod experiment bundle.",
)
parser.add_argument(
    "--command", required=True, help="Experiment command to run remotely"
)
parser.add_argument(
    "--include",
    dest="include_paths",
    action="append",
    default=[],
    metavar="PATH",
    help="Repo-relative path to include in the bundle",
)
parser.add_argument(
    "--bundle-path",
    default=DEFAULT_BUNDLE_PATH,
    help="Where to write the generated tarball",
)
parser.add_argument(
    "--results-path",
    default="storage/ai/alphazero_lite/versions/runpod-output",
    help="Remote-relative results directory",
)
parser.add_argument(
    "--local-results-path",
    default=DEFAULT_LOCAL_RESULTS_PATH,
    help="Where to download remote results locally",
)
parser.add_argument(
    "--api-key-env",
    default="RUNPOD_API_KEY",
    help="Env var that contains the Runpod API key",
)
parser.add_argument(
    "--name", default="azlite-runpod-experiment", help="Runpod pod name"
)
parser.add_argument("--pod-profile", default=None, help="Named Runpod pod profile")
parser.add_argument(
    "--run-timeout-seconds",
    type=int,
    default=None,
    help="Timeout for the remote experiment command",
)
parser.add_argument(
    "--dry-run", action="store_true", help="Print the bundle plan without writing files"
)

args = parser.parse_args()

include_paths = args.include_paths or [
    p
    for p in ["ml/alphazero_lite", "Gemfile", "Gemfile.lock"]
    if (REPO_ROOT / p).exists()
]

if args.dry_run:
    plan = build_dry_run_plan(
        name=args.name,
        command=args.command,
        bundle_path=args.bundle_path,
        results_path=args.results_path,
        local_results_path=args.local_results_path,
        include_paths=include_paths,
        api_key_env=args.api_key_env,
        pod_profile=args.pod_profile,
        run_timeout_seconds=args.run_timeout_seconds,
    )
    print(json.dumps(plan, indent=2))
    sys.exit(0)

result = orchestrate(
    name=args.name,
    command=args.command,
    bundle_path=args.bundle_path,
    results_path=args.results_path,
    local_results_path=args.local_results_path,
    include_paths=include_paths,
    api_key_env=args.api_key_env,
    pod_profile=args.pod_profile,
    run_timeout_seconds=args.run_timeout_seconds,
)

print(
    json.dumps(
        {
            "pod_id": result["pod_id"],
            "bundle_path": result["bundle_path"],
            "delete_command": result["shell_plan"]["delete_command"],
        },
        indent=2,
    )
)
