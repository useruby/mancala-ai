#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[2]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from ml.alphazero_lite.promotion_backlog import (  # noqa: E402
    initialize_manifest,
    load_manifest,
    record_artifact,
    record_multi_seed_runs,
    record_step_result,
    stage_command,
    write_manifest,
)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="script/ai/run_hard_bot_promotion_backlog",
        description="Initialize or load a hard-bot promotion backlog manifest and emit the selected stage command.",
    )
    parser.add_argument("--manifest-path", required=True, type=Path)
    parser.add_argument("--campaign-id")
    parser.add_argument("--candidate-path", type=Path)
    parser.add_argument("--config-path", type=Path)
    parser.add_argument("--parent-artifact-path", type=Path)
    parser.add_argument("--stub-promotion-report")
    parser.add_argument("--stub-forensic-report")
    parser.add_argument("--stub-multi-seed-summary")
    parser.add_argument(
        "--stage",
        required=True,
        choices=[
            "promotion_gate",
            "forensic_suite",
            "multi_seed_confirmation",
            "readiness_report",
        ],
    )
    parser.add_argument("--dry-run", action="store_true")
    return parser.parse_args()


def manifest_from_args(args: argparse.Namespace) -> dict:
    if args.manifest_path.exists():
        manifest = load_manifest(args.manifest_path)
        manifest["manifest_path"] = str(args.manifest_path)
        candidate = manifest.get("candidate", {})

        conflicts = []
        if (
            args.campaign_id is not None
            and manifest.get("campaign_id") != args.campaign_id
        ):
            conflicts.append("campaign_id")
        if args.candidate_path is not None and candidate.get("artifact_path") != str(
            args.candidate_path
        ):
            conflicts.append("candidate.artifact_path")
        if args.config_path is not None and candidate.get("config_path") != str(
            args.config_path
        ):
            conflicts.append("candidate.config_path")
        if args.parent_artifact_path is not None and candidate.get(
            "parent_artifact_path"
        ) != str(args.parent_artifact_path):
            conflicts.append("candidate.parent_artifact_path")

        if conflicts:
            raise SystemExit(
                "provided arguments conflict with existing manifest "
                + ", ".join(conflicts)
            )

        return write_manifest(args.manifest_path, manifest)

    missing = []
    if not args.campaign_id:
        missing.append("--campaign-id")
    if args.candidate_path is None:
        missing.append("--candidate-path")
    if missing:
        raise SystemExit(
            f"manifest does not exist; initialization requires: {', '.join(missing)}"
        )

    return initialize_manifest(
        manifest_path=args.manifest_path,
        campaign_id=args.campaign_id,
        candidate_path=args.candidate_path,
        config_path=args.config_path,
        parent_artifact_path=args.parent_artifact_path,
    )


def require_stub_artifact(path: str) -> Path:
    artifact_path = Path(path)
    if not artifact_path.exists():
        raise SystemExit(f"stub artifact does not exist: {artifact_path}")
    if not artifact_path.is_file():
        raise SystemExit(f"stub artifact is not a file: {artifact_path}")
    return artifact_path


def main() -> int:
    args = parse_args()
    manifest = manifest_from_args(args)
    manifest_path = args.manifest_path
    command = stage_command(stage=args.stage, manifest=manifest)

    if args.dry_run:
        print(
            json.dumps(
                {
                    "stage": args.stage,
                    "manifest_path": str(args.manifest_path),
                    "command": command,
                }
            )
        )
        return 0

    if args.stub_promotion_report and args.stage == "promotion_gate":
        stub_report = require_stub_artifact(args.stub_promotion_report)
        record_artifact(
            manifest_path, key="promotion_gate_report", value=args.stub_promotion_report
        )
        record_step_result(
            manifest_path=manifest_path,
            step_name="promotion_gate",
            status="completed",
            command=command,
            outputs={"promotion_gate_report": str(stub_report)},
            failure_summary=None,
        )
        print(
            json.dumps(
                {
                    "stage": args.stage,
                    "status": "completed",
                    "manifest_path": str(manifest_path),
                }
            )
        )
        return 0

    if args.stub_forensic_report and args.stage == "forensic_suite":
        stub_report = require_stub_artifact(args.stub_forensic_report)
        record_artifact(
            manifest_path, key="forensic_report", value=args.stub_forensic_report
        )
        record_step_result(
            manifest_path=manifest_path,
            step_name="forensic_suite",
            status="completed",
            command=command,
            outputs={"forensic_report": str(stub_report)},
            failure_summary=None,
        )
        print(
            json.dumps(
                {
                    "stage": args.stage,
                    "status": "completed",
                    "manifest_path": str(manifest_path),
                }
            )
        )
        return 0

    if args.stub_multi_seed_summary and args.stage == "multi_seed_confirmation":
        stub_summary = require_stub_artifact(args.stub_multi_seed_summary)
        summary_payload = json.loads(stub_summary.read_text(encoding="utf-8"))
        passed = summary_payload.get("passed")
        if not isinstance(passed, bool):
            raise SystemExit("stub multi-seed summary must contain boolean 'passed'")
        record_artifact(
            manifest_path, key="multi_seed_summary", value=args.stub_multi_seed_summary
        )
        record_multi_seed_runs(
            manifest_path,
            seeds=[41, 42, 43],
            summary_path=str(stub_summary),
            passed=passed,
        )
        record_step_result(
            manifest_path=manifest_path,
            step_name="multi_seed_confirmation",
            status="completed",
            command=command,
            outputs={"multi_seed_summary": str(stub_summary)},
            failure_summary=None,
        )
        print(
            json.dumps(
                {
                    "stage": args.stage,
                    "status": "completed",
                    "manifest_path": str(manifest_path),
                }
            )
        )
        return 0

    raise SystemExit(
        f"non-dry-run execution for stage '{args.stage}' is not supported. "
        "Supported modes are: --dry-run; "
        "--stub-promotion-report for stage 'promotion_gate'; "
        "--stub-forensic-report for stage 'forensic_suite'; "
        "--stub-multi-seed-summary for stage 'multi_seed_confirmation'. "
        "See --help for usage details."
    )


if __name__ == "__main__":
    raise SystemExit(main())
