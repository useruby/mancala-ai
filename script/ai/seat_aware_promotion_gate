#!/usr/bin/env python3
"""Seat-aware AlphaZero-lite promotion gate.

Evaluates a candidate against current across multiple search budgets with
forced seat-splits. Produces a seat-aware report with disadvantaged-seat
scores, candidate classification, and ranking data.

Does not train, promote, or overwrite any model.
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[2]
VENV_PYTHON = str(REPO_ROOT / ".venv/bin/python")
sys.path.insert(0, str(REPO_ROOT))

from ml.alphazero_lite.cpuct_schedule import (  # noqa: E402
    DEFAULT_RUNTIME_C_PUCT,
    default_runtime_schedule_json,
    parse_cpuct_schedule_json,
    resolve_budget_cpuct,
    schedule_definition,
)


def _find_python() -> str:
    candidates = [
        REPO_ROOT / ".venv/bin/python",
    ]
    for c in candidates:
        if c.is_file():
            return str(c)
    return sys.executable


def existing_path(value: str) -> Path:
    path = Path(value)
    if not path.exists():
        raise argparse.ArgumentTypeError(f"path does not exist: {value}")
    return path


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Seat-aware AlphaZero-lite promotion gate evaluation."
    )
    parser.add_argument(
        "--candidate-path",
        required=True,
        type=existing_path,
        help="Candidate artifact directory",
    )
    parser.add_argument(
        "--current-path",
        default="model-artifact/current",
        help="Current production artifact directory",
    )
    parser.add_argument(
        "--out", required=True, type=Path, help="Output JSON report path"
    )
    parser.add_argument("--games", type=int, default=120, help="Games per arena run")
    parser.add_argument("--seed", type=int, default=42, help="Base random seed")
    parser.add_argument(
        "--workers", type=int, default=1, help="Number of worker processes"
    )
    parser.add_argument(
        "--budget-pairs",
        default="384:256,1200:1200,1200:256,256:768",
        help="Comma-separated challenger:current simulation budget pairs",
    )
    parser.add_argument(
        "--skip-arenas",
        action="store_true",
        help="Skip arena runs; load existing JSON/JSONL from workdir",
    )
    parser.add_argument(
        "--workdir",
        default=None,
        help="Working directory for arena outputs (default: parent of --out)",
    )
    parser.add_argument("--c-puct", type=float, default=DEFAULT_RUNTIME_C_PUCT)
    parser.add_argument(
        "--c-puct-schedule-json",
        default=default_runtime_schedule_json(),
        help=(
            "Optional JSON object mapping budget labels like 1200:1200 to per-budget c_puct overrides. "
            "Default: checked-in runtime schedule. Pass '{}' for no schedule."
        ),
    )
    parser.add_argument(
        "--root-policy-mode",
        choices=("deterministic", "visit_count"),
        default="deterministic",
    )
    parser.add_argument("--root-temperature", type=float, default=0.0)
    parser.add_argument(
        "--tactical-root-bias",
        type=float,
        default=None,
        help=(
            "Optional tactical root bias override. Default: unset, which uses the checked-in "
            "arena evaluation default."
        ),
    )
    parser.add_argument("--value-trust-enabled", action="store_true")
    parser.add_argument("--value-trust-opening", type=float, default=None)
    parser.add_argument("--value-trust-midgame", type=float, default=None)
    parser.add_argument("--value-trust-late", type=float, default=None)
    parser.add_argument("--value-transform-json", default=None)
    parser.add_argument("--root-prior-transform", default=None)
    parser.add_argument("--challenger-root-prior-transform", default=None)
    parser.add_argument("--current-root-prior-transform", default=None)
    parser.add_argument(
        "--challenger-blend-current",
        action="store_true",
        help="Blend challenger values with current while retaining current policy.",
    )
    parser.add_argument("--challenger-value-alpha", type=float, default=1.0)
    parser.add_argument(
        "--challenger-value-alpha-by-budget",
        default=None,
        help="Optional JSON object of challenger:current budget labels to alpha values.",
    )
    return parser.parse_args()


def run_arena(
    challenger: str,
    current: str,
    challenger_sims: int,
    current_sims: int,
    games: int,
    seed: int,
    workers: int,
    out_json: str,
    out_jsonl: str,
    challenger_starts: int | None = None,
    c_puct: float = 1.25,
    root_policy_mode: str = "deterministic",
    root_temperature: float = 0.0,
    tactical_root_bias: float | None = None,
    value_trust_enabled: bool = False,
    value_trust_opening: float | None = None,
    value_trust_midgame: float | None = None,
    value_trust_late: float | None = None,
    value_transform_json: str | None = None,
    challenger_value_transform_json: str | None = None,
    current_value_transform_json: str | None = None,
    root_prior_transform: str | None = None,
    challenger_root_prior_transform: str | None = None,
    current_root_prior_transform: str | None = None,
    challenger_blend_current: bool = False,
    challenger_value_alpha: float = 1.0,
    timeout: int = 3600,
) -> dict:
    python = _find_python()
    cmd = [
        python,
        str(REPO_ROOT / "ml/alphazero_lite/arena.py"),
        "--challenger",
        challenger,
        "--current",
        current,
        "--challenger-simulations",
        str(challenger_sims),
        "--current-simulations",
        str(current_sims),
        "--games",
        str(games),
        "--seed",
        str(seed),
        "--workers",
        str(workers),
        "--c-puct",
        str(c_puct),
        "--min-score",
        "0.0",
        "--out",
        out_json,
        "--game-jsonl",
        out_jsonl,
        "--root-policy-mode",
        root_policy_mode,
        "--root-temperature",
        str(root_temperature),
    ]
    if tactical_root_bias is not None:
        cmd.extend(["--tactical-root-bias", str(tactical_root_bias)])
    if value_trust_enabled:
        cmd.append("--value-trust-enabled")
    if value_trust_opening is not None:
        cmd.extend(["--value-trust-opening", str(value_trust_opening)])
    if value_trust_midgame is not None:
        cmd.extend(["--value-trust-midgame", str(value_trust_midgame)])
    if value_trust_late is not None:
        cmd.extend(["--value-trust-late", str(value_trust_late)])
    if value_transform_json is not None:
        cmd.extend(["--value-transform-json", str(value_transform_json)])
    if challenger_value_transform_json is not None:
        cmd.extend(
            [
                "--challenger-value-transform-json",
                str(challenger_value_transform_json),
            ]
        )
    if current_value_transform_json is not None:
        cmd.extend(
            ["--current-value-transform-json", str(current_value_transform_json)]
        )
    if root_prior_transform is not None:
        cmd.extend(["--root-prior-transform", str(root_prior_transform)])
    if challenger_root_prior_transform is not None:
        cmd.extend(
            [
                "--challenger-root-prior-transform",
                str(challenger_root_prior_transform),
            ]
        )
    if current_root_prior_transform is not None:
        cmd.extend(
            ["--current-root-prior-transform", str(current_root_prior_transform)]
        )
    if challenger_starts is not None:
        cmd.extend(["--challenger-starts", str(challenger_starts)])
    if challenger_blend_current:
        cmd.extend(
            [
                "--challenger-blend-current",
                "--challenger-value-alpha",
                str(challenger_value_alpha),
            ]
        )

    result = subprocess.run(
        cmd,
        cwd=REPO_ROOT,
        capture_output=True,
        text=True,
        timeout=timeout,
    )
    if result.returncode != 0:
        stderr = result.stderr.strip()
        raise RuntimeError(
            f"arena failed ({challenger_sims}:{current_sims}): {stderr or ' '.join(cmd)}"
        )
    return json.loads(Path(out_json).read_text(encoding="utf-8"))


def run_seat_aware_evaluation(
    args: argparse.Namespace,
) -> dict:
    workdir = Path(args.workdir) if args.workdir else args.out.parent
    workdir.mkdir(parents=True, exist_ok=True)
    candidate_name = Path(args.candidate_path).name
    eval_dir = workdir / candidate_name
    eval_dir.mkdir(parents=True, exist_ok=True)

    budget_pairs = []
    for bp in args.budget_pairs.split(","):
        bp = bp.strip()
        if ":" in bp:
            c_str, cur_str = bp.split(":", 1)
            budget_pairs.append((int(c_str), int(cur_str)))
    cpuct_schedule = parse_cpuct_schedule_json(args.c_puct_schedule_json)
    alpha_by_budget = (
        {
            str(key): float(value)
            for key, value in json.loads(args.challenger_value_alpha_by_budget).items()
        }
        if args.challenger_value_alpha_by_budget
        else {}
    )
    schedule_manifest = schedule_definition(
        default_c_puct=float(args.c_puct), schedule=cpuct_schedule
    )

    from ml.alphazero_lite.seat_aware_arena import (
        BUDGET_PAIR_LABELS,
        build_seat_aware_report,
        compute_seat_split_metrics,
        parse_game_jsonl,
    )

    arena_results: list[dict] = []

    for chall_sims, curr_sims in budget_pairs:
        effective_c_puct = resolve_budget_cpuct(
            schedule=cpuct_schedule,
            challenger_simulations=chall_sims,
            current_simulations=curr_sims,
            default_c_puct=float(args.c_puct),
        )
        budget_label = BUDGET_PAIR_LABELS.get(
            (chall_sims, curr_sims), f"{chall_sims}_vs_{curr_sims}"
        )
        pair_dir = eval_dir / budget_label
        pair_dir.mkdir(parents=True, exist_ok=True)

        alt_json = str(pair_dir / "alternating_arena.json")
        alt_jsonl = str(pair_dir / "alternating_games.jsonl")

        print(
            f"[seat-aware] {candidate_name} {budget_label} alternating ...", flush=True
        )
        try:
            alt_report = run_arena(
                challenger=str(args.candidate_path),
                current=args.current_path,
                challenger_sims=chall_sims,
                current_sims=curr_sims,
                games=args.games,
                seed=args.seed,
                workers=args.workers,
                out_json=alt_json,
                out_jsonl=alt_jsonl,
                c_puct=effective_c_puct,
                root_policy_mode=args.root_policy_mode,
                root_temperature=args.root_temperature,
                tactical_root_bias=args.tactical_root_bias,
                value_trust_enabled=bool(args.value_trust_enabled),
                value_trust_opening=args.value_trust_opening,
                value_trust_midgame=args.value_trust_midgame,
                value_trust_late=args.value_trust_late,
                value_transform_json=args.value_transform_json,
                root_prior_transform=args.root_prior_transform,
                challenger_root_prior_transform=args.challenger_root_prior_transform,
                current_root_prior_transform=args.current_root_prior_transform,
                challenger_blend_current=bool(args.challenger_blend_current),
                challenger_value_alpha=float(
                    alpha_by_budget.get(
                        f"{chall_sims}:{curr_sims}", args.challenger_value_alpha
                    )
                ),
            )
        except RuntimeError as e:
            print(f"  FAILED alternating: {e}", flush=True)
            arena_results.append(
                {
                    "budget_label": budget_label,
                    "challenger_sims": chall_sims,
                    "current_sims": curr_sims,
                    "error": str(e),
                }
            )
            continue

        alt_entries = parse_game_jsonl(alt_jsonl)
        seat_metrics = compute_seat_split_metrics(alt_entries)

        arena_notes = (
            alt_report.get("notes", {})
            if isinstance(alt_report.get("notes"), dict)
            else {}
        )
        arena_results.append(
            {
                "budget_label": budget_label,
                "challenger_sims": chall_sims,
                "current_sims": curr_sims,
                "effective_c_puct": effective_c_puct,
                "tactical_root_bias": args.tactical_root_bias,
                "arena_score": alt_report["score"],
                "arena_wins": alt_report["wins"],
                "arena_losses": alt_report["losses"],
                "arena_draws": alt_report["draws"],
                "seat_metrics": seat_metrics,
                "search_profile": arena_notes.get("search_profile"),
                "search_profile_hash": arena_notes.get("search_profile_hash"),
                "move_time_mean_ms": arena_notes.get("move_time_mean_ms"),
                "move_time_p95_ms": arena_notes.get("move_time_p95_ms"),
            }
        )

        for forced_starts in (0, 1):
            ss_label = f"starts_{forced_starts}"
            ss_dir = pair_dir / ss_label
            ss_dir.mkdir(parents=True, exist_ok=True)
            ss_json = str(ss_dir / "arena.json")
            ss_jsonl = str(ss_dir / "games.jsonl")

            print(
                f"[seat-aware] {candidate_name} {budget_label} forced_starts={forced_starts} ...",
                flush=True,
            )
            try:
                fs_report = run_arena(
                    challenger=str(args.candidate_path),
                    current=args.current_path,
                    challenger_sims=chall_sims,
                    current_sims=curr_sims,
                    games=args.games,
                    seed=args.seed + 2000 + forced_starts,
                    workers=args.workers,
                    out_json=ss_json,
                    out_jsonl=ss_jsonl,
                    challenger_starts=forced_starts,
                    c_puct=effective_c_puct,
                    root_policy_mode=args.root_policy_mode,
                    root_temperature=args.root_temperature,
                    tactical_root_bias=args.tactical_root_bias,
                    value_trust_enabled=bool(args.value_trust_enabled),
                    value_trust_opening=args.value_trust_opening,
                    value_trust_midgame=args.value_trust_midgame,
                    value_trust_late=args.value_trust_late,
                    value_transform_json=args.value_transform_json,
                    root_prior_transform=args.root_prior_transform,
                    challenger_root_prior_transform=args.challenger_root_prior_transform,
                    current_root_prior_transform=args.current_root_prior_transform,
                    challenger_blend_current=bool(args.challenger_blend_current),
                    challenger_value_alpha=float(
                        alpha_by_budget.get(
                            f"{chall_sims}:{curr_sims}", args.challenger_value_alpha
                        )
                    ),
                )
            except RuntimeError as e:
                print(f"  FAILED forced starts={forced_starts}: {e}", flush=True)
                continue

            fs_entries = parse_game_jsonl(ss_jsonl)
            fs_seat_metrics = compute_seat_split_metrics(fs_entries)

            arena_results.append(
                {
                    "budget_label": budget_label,
                    "challenger_sims": chall_sims,
                    "current_sims": curr_sims,
                    "forced_starts": forced_starts,
                    "arena_score": fs_report["score"],
                    "arena_wins": fs_report["wins"],
                    "arena_losses": fs_report["losses"],
                    "arena_draws": fs_report["draws"],
                    "seat_metrics": fs_seat_metrics,
                    "move_time_mean_ms": arena_notes.get("move_time_mean_ms"),
                    "move_time_p95_ms": arena_notes.get("move_time_p95_ms"),
                }
            )

    report = build_seat_aware_report(
        candidate_path=str(args.candidate_path),
        current_path=args.current_path,
        arena_results=arena_results,
    )
    report["c_puct"] = float(args.c_puct)
    report["c_puct_schedule"] = schedule_manifest

    print(f"\nClassification: {report['classification']}")
    print(f"Standard alternating score: {report['standard_alternating_score']:.4f}")
    for label, br in report.get("budget_results", {}).items():
        ds = br.get("disadvantaged_seat_score")
        if ds is not None:
            print(f"  {label} disadvantaged-seat score: {ds:.4f}")

    return report


def main() -> int:
    args = parse_args()
    report = run_seat_aware_evaluation(args)
    args.out.parent.mkdir(parents=True, exist_ok=True)
    args.out.write_text(json.dumps(report, indent=2), encoding="utf-8")
    print(f"\nReport written to {args.out}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
