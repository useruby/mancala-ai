#!/usr/bin/env python3
"""Launch the stronger-bootstrap more-data experiment lane on RunPod."""

from __future__ import annotations

import argparse
import json
import shutil
import shlex
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[2]
sys.path.insert(0, str(REPO_ROOT))

from ml.alphazero_lite.runpod_experiment import build_dry_run_plan, orchestrate  # noqa: E402
from ml.alphazero_lite.stronger_bootstrap_more_data_summary import (  # noqa: E402
    summarize_downloaded_results,
    write_summary,
)

DEFAULT_CONFIG_PATH = (
    "ml/alphazero_lite/configs/aggressive_v3_stronger_bootstrap_more_data_local.json"
)
DEFAULT_RESULTS_PATH = (
    "storage/ai/alphazero_lite/versions/runpod-stronger-bootstrap-more-data"
)
DEFAULT_LOCAL_RESULTS_PATH = "/tmp/runpod-stronger-bootstrap-more-data-results"
DEFAULT_BUNDLE_PATH = str(
    REPO_ROOT / "tmp" / "runpod_stronger_bootstrap_more_data_bundle.tar.gz"
)
DEFAULT_NAME = "azlite-runpod-stronger-bootstrap-more-data"
DEFAULT_POD_PROFILE = "cpu3c-16-32"
DEFAULT_CURRENT_PATH = "model-artifact/current"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="script/ai/runpod_stronger_bootstrap_more_data_experiment",
        description="Launch the stronger-bootstrap more-data AlphaZero-lite lane on RunPod.",
    )
    parser.add_argument("--config-path", default=DEFAULT_CONFIG_PATH)
    parser.add_argument("--results-path", default=DEFAULT_RESULTS_PATH)
    parser.add_argument("--local-results-path", default=DEFAULT_LOCAL_RESULTS_PATH)
    parser.add_argument("--bundle-path", default=DEFAULT_BUNDLE_PATH)
    parser.add_argument("--api-key-env", default="RUNPOD_API_KEY")
    parser.add_argument("--name", default=DEFAULT_NAME)
    parser.add_argument("--pod-profile", default=DEFAULT_POD_PROFILE)
    parser.add_argument("--run-timeout-seconds", type=int, default=14400)
    parser.add_argument(
        "--keep-pod-on-failure", action=argparse.BooleanOptionalAction, default=True
    )
    parser.add_argument("--promotion-current-path", default=DEFAULT_CURRENT_PATH)
    parser.add_argument("--dry-run", action="store_true")
    return parser.parse_args()


def existing_repo_path(path_value: str, *, label: str) -> Path:
    path = REPO_ROOT / path_value
    if not path.exists():
        raise SystemExit(f"Missing {label}: {path_value}")
    return path


def stage_repo_directory(source_path: str, destination_path: str) -> str:
    source = REPO_ROOT / source_path
    destination = REPO_ROOT / "tmp" / "runpod-staged" / destination_path
    destination.parent.mkdir(parents=True, exist_ok=True)
    if destination.exists() or destination.is_symlink():
        if destination.is_dir() and not destination.is_symlink():
            shutil.rmtree(destination)
        else:
            destination.unlink()
    shutil.copytree(source, destination, symlinks=True)
    return destination.relative_to(REPO_ROOT).as_posix()


def lane_command(config: dict, args: argparse.Namespace) -> tuple[str, str, str, str]:
    run_id = config["run_id"]
    iteration = int(config.get("iterations", 1))
    candidate_dir_name = f"{run_id}-iter{iteration}"
    candidate_path = str(Path(config["versions_dir"]) / candidate_dir_name)
    promotion_out = str(Path(args.results_path) / "local_promotion_gate.json")
    pre_pipeline_commands = [f"mkdir -p {shlex.quote(args.results_path)}"]
    config_current_path = config.get("current_path")
    if (
        isinstance(config_current_path, str)
        and config_current_path != args.promotion_current_path
    ):
        pre_pipeline_commands.extend(
            [
                f"mkdir -p {shlex.quote(config_current_path)}",
                f"cp -R {shlex.quote(args.promotion_current_path)}/. {shlex.quote(config_current_path)}/",
            ]
        )
    command = " && ".join(
        [
            *pre_pipeline_commands,
            f".venv/bin/python ml/alphazero_lite/pipeline.py --config {shlex.quote(args.config_path)} --skip-step rules_parity_fuzz",
            f"cp -R {shlex.quote(candidate_path)} {shlex.quote(args.results_path)}/",
            " ".join(
                [
                    "script/ai/local_promotion_gate",
                    f"--candidate-path {shlex.quote(candidate_path)}",
                    f"--config-path {shlex.quote(args.config_path)}",
                    f"--current-path {shlex.quote(args.promotion_current_path)}",
                    f"--out {shlex.quote(promotion_out)}",
                ]
            ),
        ]
    )
    downloaded_results_root = str(
        Path(args.local_results_path) / Path(args.results_path).name
    )
    return command, candidate_dir_name, candidate_path, downloaded_results_root


def include_paths(args: argparse.Namespace, config: dict) -> list[str]:
    paths = [
        "ml/alphazero_lite",
        "script/ai",
        args.config_path,
        "model-artifact/current",
        "Gemfile",
        "Gemfile.lock",
        "bin/rails",
        "app/models",
        "config",
        "test/fixtures/ai/superhuman_regression_positions.json",
    ]
    if args.promotion_current_path != "model-artifact/current":
        paths.append(args.promotion_current_path)
    config_current_path = config.get("current_path")
    if (
        config_current_path == "storage/ai/alphazero_lite/current"
        and not (REPO_ROOT / config_current_path).exists()
    ):
        paths.append(
            stage_repo_directory("model-artifact/current", config_current_path)
        )
    elif isinstance(config_current_path, str):
        paths.append(config_current_path)
    existing_paths = []
    for path in list(dict.fromkeys(paths)):
        if (REPO_ROOT / path).exists():
            existing_paths.append(path)
    return existing_paths


def dry_run_payload(args: argparse.Namespace, config: dict) -> dict:
    command, candidate_dir_name, candidate_path, downloaded_results_root = lane_command(
        config, args
    )
    plan = build_dry_run_plan(
        name=args.name,
        command=command,
        bundle_path=args.bundle_path,
        results_path=args.results_path,
        local_results_path=args.local_results_path,
        include_paths=include_paths(args, config),
        api_key_env=args.api_key_env,
        pod_profile=args.pod_profile,
        run_timeout_seconds=args.run_timeout_seconds,
        keep_pod_on_failure=args.keep_pod_on_failure,
    )
    plan.update(
        {
            "config_path": args.config_path,
            "candidate_dir_name": candidate_dir_name,
            "candidate_path": candidate_path,
            "downloaded_results_root": downloaded_results_root,
            "summary_path": str(Path(downloaded_results_root) / "issue1_summary.json"),
        }
    )
    return plan


def main() -> int:
    args = parse_args()
    config_path = existing_repo_path(args.config_path, label="config path")
    existing_repo_path("script/ai/local_promotion_gate", label="required script")
    existing_repo_path(args.promotion_current_path, label="promotion current path")
    config = json.loads(config_path.read_text(encoding="utf-8"))

    if args.dry_run:
        print(json.dumps(dry_run_payload(args, config), indent=2))
        return 0

    command, _, _, _ = lane_command(config, args)
    result = None
    orchestrate_error = None
    try:
        result = orchestrate(
            name=args.name,
            command=command,
            bundle_path=args.bundle_path,
            results_path=args.results_path,
            local_results_path=args.local_results_path,
            include_paths=include_paths(args, config),
            api_key_env=args.api_key_env,
            pod_profile=args.pod_profile,
            run_timeout_seconds=args.run_timeout_seconds,
            keep_pod_on_failure=args.keep_pod_on_failure,
        )
    except Exception as error:
        orchestrate_error = error

    try:
        summary = write_summary(
            summarize_downloaded_results(
                local_results_path=args.local_results_path,
                results_path=args.results_path,
                experiment_report_path=(result or {}).get("experiment_report_path"),
                experiment_passed=(result or {}).get("experiment_passed"),
                manifest_path=(result or {}).get("manifest_path"),
                manifest_status=(result or {}).get("manifest_status"),
            )
        )
    except Exception:
        if orchestrate_error is not None:
            raise orchestrate_error
        raise

    print(json.dumps(summary, indent=2))
    if summary["recommendation"] in ("confirm", "promote"):
        return 0
    if orchestrate_error is not None and not summary["completed"]:
        raise orchestrate_error
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
