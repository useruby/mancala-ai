#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[2]


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="script/ai/report_hard_bot_promotion_readiness",
        description="Print the hard-bot promotion readiness summary as JSON.",
    )
    parser.add_argument("--manifest-path", required=True, type=Path)
    return parser.parse_args()


def main() -> int:
    if str(REPO_ROOT) not in sys.path:
        sys.path.insert(0, str(REPO_ROOT))
    from ml.alphazero_lite.promotion_backlog import evaluate_readiness

    args = parse_args()
    readiness = evaluate_readiness(manifest_path=args.manifest_path)
    print(json.dumps(readiness))
    return 0 if readiness["passed"] else 1


if __name__ == "__main__":
    raise SystemExit(main())
