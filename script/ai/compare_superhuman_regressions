#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "optparse"
require_relative "../../config/environment"

options = {
  positions: Rails.root.join("test/fixtures/ai/superhuman_regression_positions.json").to_s,
  baseline_artifact: AI::AlphaZeroLite::Chooser::ARTIFACT_PATH.to_s,
  candidate_artifact: AI::AlphaZeroLite::Chooser::ARTIFACT_PATH.to_s,
  simulations: nil,
  out: nil,
  search_options: {}
}

parser = OptionParser.new do |opts|
  opts.banner = "Usage: script/ai/compare_superhuman_regressions [--positions PATH] [--baseline-artifact PATH] [--candidate-artifact PATH] [--simulations N]"

  opts.on("--positions PATH") { |value| options[:positions] = value }
  opts.on("--baseline-artifact PATH") { |value| options[:baseline_artifact] = value }
  opts.on("--candidate-artifact PATH") { |value| options[:candidate_artifact] = value }
  opts.on("--simulations N", Integer) { |value| options[:simulations] = value }
  opts.on("--out PATH") { |value| options[:out] = value }
  opts.on("--fpu-mode VALUE") { |value| options[:search_options][:fpu_mode] = value.to_sym }
  opts.on("--reuse-subtree") { options[:search_options][:reuse_subtree] = true }
  opts.on("--no-reuse-subtree") { options[:search_options][:reuse_subtree] = false }
  opts.on("--normalize-values") { options[:search_options][:normalize_values] = true }
  opts.on("--no-normalize-values") { options[:search_options][:normalize_values] = false }
  opts.on("--root-policy-mode VALUE") { |value| options[:search_options][:root_policy_mode] = value.to_sym }
  opts.on("--tactical-root-bias VALUE", Float) { |value| options[:search_options][:tactical_root_bias] = value }
end

parser.parse!(ARGV)

search_options = options[:search_options].empty? ? nil : options[:search_options]
baseline_results = AI::AlphaZeroLite::RegressionSuite.evaluate_positions(
  path: options[:positions],
  artifact_path: options[:baseline_artifact],
  simulations: options[:simulations],
  search_options: search_options
)
candidate_results = AI::AlphaZeroLite::RegressionSuite.evaluate_positions(
  path: options[:positions],
  artifact_path: options[:candidate_artifact],
  simulations: options[:simulations],
  search_options: search_options
)
comparisons = AI::AlphaZeroLite::RegressionSuite.compare_results(
  baseline_results: baseline_results,
  candidate_results: candidate_results
)

payload = JSON.pretty_generate(
  baseline_artifact_path: options[:baseline_artifact],
  candidate_artifact_path: options[:candidate_artifact],
  positions_path: options[:positions],
  comparisons: comparisons
)

Pathname(options[:out]).write(payload) if options[:out]
puts payload

passed = baseline_results.any? && candidate_results.any? && comparisons.any? && comparisons.all? { |comparison| comparison.fetch(:candidate_passed) }
exit(passed ? 0 : 1)
