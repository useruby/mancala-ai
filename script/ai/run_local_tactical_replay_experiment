def build_dry_run_payload(args, root) -> dict:
    validate_args(args, root)
    validate_stage_prerequisites(args, root)
    python_bin = python_executable(root)
    paths = build_run_paths(args.output_root, args.run_id)
    config_path = Path(args.base_config)
    if not config_path.is_absolute():
        config_path = root / config_path

    planned_commands = build_stage_commands(
        root=root,
        python_bin=python_bin,
        run_id=args.run_id,
        current_path=args.current_path,
        forensic_suite=args.forensic_suite,
        runtime_config_path=paths["runtime_config_path"],
        output_root=Path(args.output_root),
        base_config_path=config_path,
        reference_artifact_path=resolve_path(
            root, getattr(args, "reference_artifact", None)
        ),
        exploratory_summary_path=resolve_path(
            root, getattr(args, "exploratory_summary", None)
        ),
    )
    stages = planned_stages(args)
    command_names_by_stage = command_names_by_stage_for(stages)
    command_names_by_stage["train"] = build_train_command_names(config_path)
    all_commands = {
        stage: [
            planned_commands[command_name]
            for command_name in command_names_by_stage.get(stage, [])
        ]
        for stage in [
            "mine",
            "label",
            "train",
            "select",
            "validation_pack",
            "final_holdout",
            "decision",
        ]
    }

    return {
        "run_id": args.run_id,
        "current_path": args.current_path,
        "forensic_suite": args.forensic_suite,
        "config_path": str(config_path),
        "injected_overrides": {
            "base_config": str(config_path),
            "current_path": args.current_path,
            "forensic_suite": args.forensic_suite,
            "reference_artifact": str(
                resolve_path(root, getattr(args, "reference_artifact", None))
                or (paths["inputs_dir"] / "reference_moves.json")
            ),
            "runtime_config_path": str(paths["runtime_config_path"]),
            "exploratory_summary": str(
                resolve_path(root, getattr(args, "exploratory_summary", None))
                or (paths["base_dir"] / "exploratory" / "aggregate_summary.json")
            ),
        },
        "stages": stages,
        "summary_path": str(paths["summary_path"]),
        "paths": {key: str(value) for key, value in paths.items()},
        "commands": {stage: all_commands[stage] for stage in stages},
    }


def main(argv=None) -> int:
    root = repo_root()
    args = parse_args(argv)
    payload = build_dry_run_payload(args, root) if args.dry_run else run(args, root)
    print(json.dumps(payload))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
