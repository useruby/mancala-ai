#!/usr/bin/env python3
import argparse
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path


STAGES = [
    "mine",
    "label",
    "train",
    "select",
    "validation_pack",
    "final_holdout",
    "decision",
]


def repo_root() -> Path:
    return Path(__file__).resolve().parents[2]


def python_executable(root: Path) -> str:
    if os.environ.get("AZLITE_EXPERIMENT_PYTHON"):
        return os.environ["AZLITE_EXPERIMENT_PYTHON"]

    candidates = [root / ".venv/bin/python"]
    candidates.extend(parent / ".venv/bin/python" for parent in root.parents)
    for candidate in candidates:
        if candidate.is_file() and os.access(candidate, os.X_OK):
            return str(candidate)

    return sys.executable


def load_json(path: Path) -> dict:
    return json.loads(path.read_text(encoding="utf-8"))


def selection_manifest_payload(
    *,
    artifact_path: Path,
    selected_target: Path,
    selection_rule: str,
    candidate_count: int,
) -> dict:
    return {
        "selected_artifact": str(artifact_path),
        "selected_target": str(selected_target.resolve()),
        "selection_rule": selection_rule,
        "candidate_count": candidate_count,
    }


def default_fixed_replay_sources() -> list[dict[str, int | str]]:
    return [
        {
            "path": "ml/alphazero_lite/tactical_opening_capture_family_replay.jsonl",
            "weight": 8,
        }
    ]


def default_stable_failure_family_replay_sources() -> list[dict[str, int | str]]:
    return [
        {
            "path": "ml/alphazero_lite/tactical_stable_failure_family_replay.jsonl",
            "weight": 8,
        }
    ]


def opening_capture_family_replay_path(run_paths: dict[str, Path]) -> Path:
    return run_paths["inputs_dir"] / "tactical_opening_capture_family_replay.jsonl"


def stable_failure_family_replay_path(run_paths: dict[str, Path]) -> Path:
    return run_paths["inputs_dir"] / "tactical_stable_failure_family_replay.jsonl"


def stable_failure_family_replay_summary_path(run_paths: dict[str, Path]) -> Path:
    return (
        run_paths["inputs_dir"] / "tactical_stable_failure_family_replay_summary.json"
    )


def fixed_replay_artifact_path_for_sources(
    fixed_replay_sources: list[dict[str, int | str]], run_paths: dict[str, Path]
) -> Path | None:
    if fixed_replay_sources == default_fixed_replay_sources():
        return opening_capture_family_replay_path(run_paths)
    if fixed_replay_sources == default_stable_failure_family_replay_sources():
        return stable_failure_family_replay_path(run_paths)
    return None


def runtime_fixed_replay_sources(
    config: dict, *, fixed_replay_artifact_path: Path | None = None
) -> list[dict]:
    fixed_replay_sources = list(config.get("fixed_replay_sources", []))
    if fixed_replay_sources == [
        {"path": "ml/alphazero_lite/tactical_capture_protection.jsonl", "weight": 8}
    ]:
        fixed_replay_sources = list(default_fixed_replay_sources())
    if fixed_replay_artifact_path is None:
        return fixed_replay_sources
    artifact_source = None
    if fixed_replay_sources == default_fixed_replay_sources():
        artifact_source = default_fixed_replay_sources()[0]
    elif fixed_replay_sources == default_stable_failure_family_replay_sources():
        artifact_source = default_stable_failure_family_replay_sources()[0]
    if artifact_source is None:
        return fixed_replay_sources
    return [
        {**source, "path": str(fixed_replay_artifact_path)}
        if source == artifact_source
        else source
        for source in fixed_replay_sources
    ]


def set_python_bin(command, python_bin):
    if command and command[0] == ".venv/bin/python":
        command[0] = python_bin


def parse_args(argv=None) -> argparse.Namespace:
    parser = argparse.ArgumentParser()
    parser.add_argument("--run-id", required=True)
    parser.add_argument("--output-root", required=True)
    parser.add_argument("--current-path", required=True)
    parser.add_argument("--base-config", required=True)
    parser.add_argument("--forensic-suite", required=True)
    parser.add_argument("--reference-artifact")
    parser.add_argument("--start-stage", choices=STAGES, default="mine")
    parser.add_argument("--skip-stage", action="append", default=[])
    parser.add_argument("--selected-artifact")
    parser.add_argument("--exploratory-summary")
    parser.add_argument("--dry-run", action="store_true")
    return parser.parse_args(argv)


def build_run_paths(output_root, run_id) -> dict[str, Path]:
    base_dir = Path(output_root) / run_id
    return {
        "base_dir": base_dir,
        "inputs_dir": base_dir / "inputs",
        "runtime_config_path": base_dir / "inputs" / "runtime_config.json",
        "manifest_path": base_dir / "run_manifest.json",
        "summary_path": base_dir / "summary.json",
        "selection_dir": base_dir / "selection",
    }


def resolve_path(root: Path, value: str | None) -> Path | None:
    if value is None:
        return None
    path = Path(value)
    return path if path.is_absolute() else root / path


def planned_stages(args) -> list[str]:
    start_index = STAGES.index(getattr(args, "start_stage", "mine"))
    skip_stages = set(getattr(args, "skip_stage", []) or [])
    stages = list(STAGES[start_index:])
    if getattr(args, "start_stage", "mine") == "mine" and not getattr(
        args, "selected_artifact", None
    ):
        stages = stages[: stages.index("select") + 1]
    return [stage for stage in stages if stage not in skip_stages]


def command_names_by_stage_for(requested_stages: list[str]) -> dict[str, list[str]]:
    validation_pack_commands = [
        "build_forensic_references_command",
        "candidate_forensic_command",
        "current_forensic_command",
        "arena_command",
        "bucket_gate_command",
        "regression_command",
    ]
    final_holdout_commands = [
        "build_forensic_references_command",
        "candidate_forensic_command",
        "current_forensic_command",
        "arena_command",
        "candidate_mcts_command",
        "current_mcts_command",
        "aggregate_holdout_command",
        "bucket_gate_command",
        "regression_command",
        "local_promotion_gate_command",
    ]
    if "validation_pack" in requested_stages:
        final_holdout_commands = [
            "candidate_mcts_command",
            "current_mcts_command",
            "aggregate_holdout_command",
            "local_promotion_gate_command",
        ]

    return {
        "mine": ["prepare_forensic_mining_input_command", "mine_command"],
        "label": ["label_command"],
        "train": ["train_command"],
        "validation_pack": validation_pack_commands,
        "final_holdout": final_holdout_commands,
        "decision": ["decision_command"],
    }


def validate_args(args, root) -> None:
    if args.start_stage == "final_holdout" and not getattr(
        args, "selected_artifact", None
    ):
        raise SystemExit("final_holdout start requires a selected artifact")

    if getattr(args, "selected_artifact", None):
        selected_artifact = resolve_path(root, args.selected_artifact)
        if selected_artifact is not None and not selected_artifact.exists():
            raise SystemExit(f"selected artifact does not exist: {selected_artifact}")


def validate_stage_prerequisites(args, root) -> None:
    run_paths = build_run_paths(args.output_root, args.run_id)
    requested_stages = planned_stages(args)
    train_root = run_paths["base_dir"] / "versions"
    selection_artifact = run_paths["selection_dir"] / "artifact"
    mined_states_path = run_paths["inputs_dir"] / "mined_hard_states.jsonl"
    labeled_states_path = run_paths["inputs_dir"] / "labeled_tactical_states.jsonl"
    exploratory_summary_path = resolve_path(
        root, getattr(args, "exploratory_summary", None)
    )
    if exploratory_summary_path is None:
        exploratory_summary_path = (
            run_paths["base_dir"] / "exploratory" / "aggregate_summary.json"
        )
    bucket_gate_path = run_paths["base_dir"] / "final" / "bucket_gate.json"
    promotion_gate_path = run_paths["base_dir"] / "final" / "local_promotion_gate.json"

    if (
        "label" in requested_stages
        and "mine" not in requested_stages
        and not mined_states_path.exists()
    ):
        raise SystemExit(f"missing prerequisite: {mined_states_path}")

    if (
        "train" in requested_stages
        and "label" not in requested_stages
        and not labeled_states_path.exists()
    ):
        raise SystemExit(f"missing prerequisite: {labeled_states_path}")

    if (
        "select" in requested_stages
        and "train" not in requested_stages
        and not getattr(args, "selected_artifact", None)
    ):
        if not candidate_artifact_dirs(train_root):
            raise SystemExit(
                f"missing prerequisite candidate artifacts under {train_root}"
            )

    if (
        any(
            stage in requested_stages
            for stage in ["validation_pack", "final_holdout", "decision"]
        )
        and "select" not in requested_stages
    ):
        explicit_selected = resolve_path(root, getattr(args, "selected_artifact", None))
        if explicit_selected is None and not selection_artifact.exists():
            raise SystemExit(f"missing prerequisite: {selection_artifact}")

    if (
        "decision" in requested_stages
        and "mine" not in requested_stages
        and getattr(args, "exploratory_summary", None) is None
    ):
        raise SystemExit(
            "resumed decision flow requires an explicit exploratory summary"
        )

    if "decision" in requested_stages and not exploratory_summary_path.exists():
        raise SystemExit(f"missing prerequisite: {exploratory_summary_path}")

    if "decision" in requested_stages and exploratory_summary_path.exists():
        exploratory_summary = load_json(exploratory_summary_path)
        if not exploratory_summary.get("passed"):
            raise SystemExit(
                f"exploratory confirmation failed: {exploratory_summary_path}"
            )

    if "decision" in requested_stages and "final_holdout" not in requested_stages:
        if not bucket_gate_path.exists():
            raise SystemExit(f"missing prerequisite: {bucket_gate_path}")
        if not promotion_gate_path.exists():
            raise SystemExit(f"missing prerequisite: {promotion_gate_path}")


def candidate_artifact_dirs(train_root) -> list[Path]:
    train_root = Path(train_root)
    if not train_root.exists():
        return []

    candidates = []
    for path in sorted(train_root.iterdir()):
        if path.is_dir() and (path / "model.npz").exists():
            candidates.append(path)
    return candidates


def select_candidate(train_root, selection_dir) -> Path:
    candidates = candidate_artifact_dirs(train_root)
    if not candidates:
        raise SystemExit(f"no candidate artifacts found under {train_root}")
    if len(candidates) != 1:
        raise SystemExit(f"multiple candidate artifacts found under {train_root}")
    return candidates[0]


def run_command(command, cwd, allowed_returncodes=(0,)) -> dict:
    completed = subprocess.run(command, cwd=cwd, check=False)
    if completed.returncode not in allowed_returncodes:
        raise SystemExit(
            f"command failed with exit code {completed.returncode}: {command}"
        )
    return {
        "command": list(command),
        "cwd": str(cwd),
        "returncode": completed.returncode,
    }


def write_json(path, payload) -> None:
    path = Path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2), encoding="utf-8")


def allowed_returncodes_for(command_name: str) -> tuple[int, ...]:
    if command_name == "bucket_gate_command":
        return (0, 1)
    return (0,)


def materialize_selected_artifact(selection_dir: Path, selected_target: Path) -> Path:
    selection_dir.mkdir(parents=True, exist_ok=True)
    artifact_path = selection_dir / "artifact"
    resolved_target = selected_target.resolve()

    if artifact_path.is_symlink() or artifact_path.is_file():
        artifact_path.unlink()
    elif artifact_path.exists():
        shutil.rmtree(artifact_path)

    try:
        artifact_path.symlink_to(resolved_target, target_is_directory=True)
    except OSError:
        shutil.copytree(resolved_target, artifact_path)

    return artifact_path


def run(args, root) -> dict:
    validate_args(args, root)
    validate_stage_prerequisites(args, root)

    run_paths = build_run_paths(args.output_root, args.run_id)
    run_paths["base_dir"].mkdir(parents=True, exist_ok=True)
    config_path = resolve_path(root, args.base_config)
    assert config_path is not None
    replay_dataset_path = run_paths["inputs_dir"] / "labeled_tactical_states.jsonl"
    fixed_replay_artifact_path = None
    fixed_replay_sources = runtime_fixed_replay_sources(load_json(config_path))
    fixed_replay_artifact_path = fixed_replay_artifact_path_for_sources(
        fixed_replay_sources, run_paths
    )
    write_runtime_config(
        base_config_path=config_path,
        destination_path=run_paths["runtime_config_path"],
        run_id=args.run_id,
        current_path=args.current_path,
        replay_dataset_path=replay_dataset_path,
        fixed_replay_artifact_path=fixed_replay_artifact_path,
    )
    stage_commands = build_stage_commands(
        root=root,
        python_bin=python_executable(root),
        run_id=args.run_id,
        current_path=args.current_path,
        forensic_suite=args.forensic_suite,
        runtime_config_path=run_paths["runtime_config_path"],
        output_root=Path(args.output_root),
        base_config_path=config_path,
        reference_artifact_path=resolve_path(
            root, getattr(args, "reference_artifact", None)
        ),
        exploratory_summary_path=resolve_path(
            root, getattr(args, "exploratory_summary", None)
        ),
    )

    executed_stages: list[str] = []
    command_results: list[dict] = []
    requested_stages = planned_stages(args)
    selection_manifest = None
    explicit_selected = resolve_path(root, getattr(args, "selected_artifact", None))

    command_names_by_stage = command_names_by_stage_for(requested_stages)
    command_names_by_stage["train"] = build_train_command_names(config_path)

    if explicit_selected is not None and any(
        stage in requested_stages
        for stage in ["validation_pack", "final_holdout", "decision"]
    ):
        artifact_path = materialize_selected_artifact(
            run_paths["selection_dir"], explicit_selected
        )
        selection_manifest = selection_manifest_payload(
            artifact_path=artifact_path,
            selected_target=explicit_selected,
            selection_rule="explicit_artifact",
            candidate_count=1,
        )
        write_json(
            run_paths["selection_dir"] / "selection_manifest.json", selection_manifest
        )

    for stage in requested_stages:
        if stage == "select":
            if explicit_selected is not None:
                selected_target = explicit_selected
                selection_rule = "explicit_artifact"
                candidate_count = 1
            else:
                selected_target = select_candidate(
                    run_paths["base_dir"] / "versions", run_paths["selection_dir"]
                )
                selection_rule = "single_candidate"
                candidate_count = len(
                    candidate_artifact_dirs(run_paths["base_dir"] / "versions")
                )

            artifact_path = materialize_selected_artifact(
                run_paths["selection_dir"], selected_target
            )
            selection_manifest = selection_manifest_payload(
                artifact_path=artifact_path,
                selected_target=selected_target,
                selection_rule=selection_rule,
                candidate_count=candidate_count,
            )
            write_json(
                run_paths["selection_dir"] / "selection_manifest.json",
                selection_manifest,
            )
            executed_stages.append(stage)
            continue

        stage_command_names = command_names_by_stage.get(stage, [])
        if not stage_command_names:
            continue

        for command_name in stage_command_names:
            command_results.append(
                run_command(
                    stage_commands[command_name],
                    root,
                    allowed_returncodes=allowed_returncodes_for(command_name),
                )
            )
        executed_stages.append(stage)

    if selection_manifest is None:
        selection_manifest_path = run_paths["selection_dir"] / "selection_manifest.json"
        if selection_manifest_path.exists():
            selection_manifest = load_json(selection_manifest_path)

    manifest = {
        "schema": "tactical_replay_run_manifest_v1",
        "run_id": args.run_id,
        "status": "completed",
        "executed_stages": executed_stages,
        "runtime_config_path": str(run_paths["runtime_config_path"]),
        "summary_path": str(run_paths["summary_path"]),
        "selection_manifest_path": str(
            run_paths["selection_dir"] / "selection_manifest.json"
        ),
    }
    write_json(run_paths["manifest_path"], manifest)

    summary = {
        "schema": "tactical_replay_summary_v1",
        "run_id": args.run_id,
        "executed_stages": executed_stages,
        "runtime_config_path": str(run_paths["runtime_config_path"]),
        "selection_manifest": selection_manifest,
        "command_results": command_results,
        "status": "completed",
    }
    write_json(run_paths["summary_path"], summary)
    return summary


def write_runtime_config(
    *,
    base_config_path: Path,
    destination_path: Path,
    run_id: str,
    current_path: str,
    replay_dataset_path: Path,
    fixed_replay_artifact_path: Path | None = None,
) -> dict:
    config = load_json(base_config_path)
    base_dir = destination_path.parent.parent
    python_bin = python_executable(repo_root())

    config["run_id"] = run_id
    config["versions_dir"] = str(base_dir / "versions")
    config["current_path"] = current_path
    config["parent_artifact_path"] = current_path
    fixed_replay_sources = runtime_fixed_replay_sources(
        config,
        fixed_replay_artifact_path=fixed_replay_artifact_path,
    )
    config["fixed_replay_sources"] = [
        {"path": str(replay_dataset_path), "weight": 1},
        *fixed_replay_sources,
    ]

    for step in config.get("steps", []):
        command = list(step.get("command", []))
        if not command:
            continue
        set_python_bin(command, python_bin)
        step["command"] = command

    destination_path.parent.mkdir(parents=True, exist_ok=True)
    destination_path.write_text(json.dumps(config, indent=2), encoding="utf-8")
    return config


def should_build_opening_capture_family_replay(base_config_path: Path) -> bool:
    fixed_replay_sources = runtime_fixed_replay_sources(load_json(base_config_path))
    return fixed_replay_sources == default_fixed_replay_sources()


def should_build_stable_failure_family_replay(base_config_path: Path) -> bool:
    fixed_replay_sources = runtime_fixed_replay_sources(load_json(base_config_path))
    return fixed_replay_sources == default_stable_failure_family_replay_sources()


def build_train_command_names(base_config_path: Path) -> list[str]:
    train_commands = ["train_command"]
    if should_build_opening_capture_family_replay(base_config_path):
        train_commands.insert(0, "build_fixed_replay_command")
    elif should_build_stable_failure_family_replay(base_config_path):
        train_commands.insert(0, "build_fixed_replay_command")
        train_commands.insert(0, "build_forensic_references_command")
    return train_commands


def build_fixed_replay_command(
    *,
    root: Path,
    python_bin: str,
    base_config_path: Path,
    run_paths: dict[str, Path],
    reference_artifact_path: Path,
) -> list[str] | None:
    if should_build_opening_capture_family_replay(base_config_path):
        return [
            python_bin,
            str(
                root
                / "ml/alphazero_lite/build_tactical_opening_capture_family_replay.py"
            ),
            "--out",
            str(opening_capture_family_replay_path(run_paths)),
        ]

    if should_build_stable_failure_family_replay(base_config_path):
        return [
            python_bin,
            str(
                root
                / "ml/alphazero_lite/build_tactical_stable_failure_family_replay.py"
            ),
            "--reference",
            str(reference_artifact_path),
            "--out",
            str(stable_failure_family_replay_path(run_paths)),
            "--summary-out",
            str(stable_failure_family_replay_summary_path(run_paths)),
        ]

    return None


def build_stage_commands(
    *,
    root: Path,
    python_bin: str,
    run_id: str,
    current_path: str,
    forensic_suite: str,
    runtime_config_path: Path,
    output_root: Path,
    base_config_path: Path,
    reference_artifact_path: Path | None = None,
    exploratory_summary_path: Path | None = None,
) -> dict[str, list[str]]:
    run_paths = build_run_paths(output_root, run_id)
    final_dir = run_paths["base_dir"] / "final"
    selection_artifact = run_paths["selection_dir"] / "artifact"
    mining_forensic_input_path = run_paths["inputs_dir"] / "mining_forensic_input.json"
    mined_states_path = run_paths["inputs_dir"] / "mined_hard_states.jsonl"
    mined_report_path = run_paths["inputs_dir"] / "mined_hard_states_report.json"
    labeled_states_path = run_paths["inputs_dir"] / "labeled_tactical_states.jsonl"
    tactical_train_path = run_paths["inputs_dir"] / "tactical_replay_train.jsonl"
    preservation_train_path = (
        run_paths["inputs_dir"] / "preservation_replay_train.jsonl"
    )
    if reference_artifact_path is None:
        reference_artifact_path = run_paths["inputs_dir"] / "reference_moves.json"
    candidate_forensic_path = final_dir / "selected_candidate_forensics.json"
    current_forensic_path = final_dir / "baseline_candidate_forensics.json"
    arena_report_path = final_dir / "arena_seed_1041.json"
    candidate_mcts_path = final_dir / "candidate_mcts_seed_2041.json"
    current_mcts_path = final_dir / "current_mcts_seed_2041.json"
    arena_holdout_path = final_dir / "arena_holdout.json"
    candidate_mcts_holdout_path = final_dir / "candidate_mcts_holdout.json"
    current_mcts_holdout_path = final_dir / "current_mcts_holdout.json"
    bucket_gate_path = final_dir / "bucket_gate.json"
    regression_report_path = final_dir / "candidate_regression_suite.json"
    promotion_gate_path = final_dir / "local_promotion_gate.json"
    decision_path = final_dir / "tactical_lane_decision.json"
    if exploratory_summary_path is None:
        exploratory_summary_path = (
            run_paths["base_dir"] / "exploratory" / "aggregate_summary.json"
        )

    commands = {
        "prepare_forensic_mining_input_command": [
            python_bin,
            str(root / "ml/alphazero_lite/run_forensic_suite.py"),
            "--suite",
            forensic_suite,
            "--current-artifact",
            current_path,
            "--challenger-artifact",
            current_path,
            "--out",
            str(mining_forensic_input_path),
        ],
        "mine_command": [
            python_bin,
            str(root / "ml/alphazero_lite/mine_hard_states.py"),
            "--inputs",
            str(mining_forensic_input_path),
            "--out-jsonl",
            str(mined_states_path),
            "--out-report",
            str(mined_report_path),
        ],
        "label_command": [
            python_bin,
            str(root / "ml/alphazero_lite/label_tactical_states.py"),
            "--input",
            str(mined_states_path),
            "--policy-simulations",
            "1200",
            "--value-simulations",
            "1200",
            "--seed",
            "42",
            "--policy-target-mode",
            "sharpened",
            "--value-target-mode",
            "sharpened",
            "--input-encoding",
            "kalah_v3",
            "--out-labeled",
            str(labeled_states_path),
            "--out-tactical-train",
            str(tactical_train_path),
            "--out-preservation-train",
            str(preservation_train_path),
        ],
        "train_command": [
            python_bin,
            str(root / "ml/alphazero_lite/pipeline.py"),
            "--config",
            str(runtime_config_path),
        ],
        "build_forensic_references_command": [
            python_bin,
            str(root / "ml/alphazero_lite/build_forensic_references.py"),
            "--suite",
            forensic_suite,
            "--out",
            str(reference_artifact_path),
            "--policy-simulations",
            "1200",
            "--value-simulations",
