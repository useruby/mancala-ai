#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import shutil
import shlex
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[2]
sys.path.insert(0, str(REPO_ROOT))

from ml.alphazero_lite.runpod_experiment import build_dry_run_plan, orchestrate  # noqa: E402

DEFAULT_CANDIDATE_PATH = (
    "/tmp/azlite_v3_superhuman_versions/aggressive-v3-superhuman-iter2"
)
DEFAULT_CURRENT_PATH = "model-artifact/current"
DEFAULT_SIMULATIONS = "384,512,640,768,896"
DEFAULT_OUTPUT_ROOT = "/tmp/azlite_v3_superhuman_budget_sweep"
DEFAULT_RESULTS_PATH = (
    "storage/ai/alphazero_lite/versions/runpod-superhuman-budget-sweep"
)
DEFAULT_LOCAL_RESULTS_PATH = "/tmp/runpod-superhuman-budget-sweep-results"
DEFAULT_BUNDLE_PATH = str(
    REPO_ROOT / "tmp" / "runpod_superhuman_budget_sweep_bundle.tar.gz"
)
DEFAULT_NAME = "azlite-runpod-superhuman-budget-sweep"
DEFAULT_POD_PROFILE = "cpu3c-16-32"
DEFAULT_RESULT_SUMMARY_NAME = "aggregate_summary.json"


def stage_tmp_bundle_path(path_value: str) -> str:
    path = Path(path_value)
    if not path.is_absolute() or not path_value.startswith("/tmp/"):
        return path.as_posix()
    if not path.exists():
        return path.relative_to("/").as_posix()
    staged_path = REPO_ROOT / path.relative_to("/")
    staged_path.parent.mkdir(parents=True, exist_ok=True)
    if staged_path.exists() or staged_path.is_symlink():
        if staged_path.is_dir() and not staged_path.is_symlink():
            shutil.rmtree(staged_path)
        else:
            staged_path.unlink()
    shutil.copytree(path, staged_path, symlinks=True)
    return staged_path.relative_to(REPO_ROOT).as_posix()


def stage_absolute_bundle_path(path_value: str) -> str:
    path = Path(path_value)
    if not path.is_absolute() or path_value.startswith("/tmp/"):
        return path.as_posix()
    staged_path = REPO_ROOT / "tmp" / "runpod-staged" / path.relative_to("/")
    staged_path.parent.mkdir(parents=True, exist_ok=True)
    if staged_path.exists() or staged_path.is_symlink():
        if staged_path.is_dir() and not staged_path.is_symlink():
            shutil.rmtree(staged_path)
        else:
            staged_path.unlink()
    shutil.copytree(path, staged_path, symlinks=True)
    return staged_path.relative_to(REPO_ROOT).as_posix()


def repo_bundle_path(path_value: str) -> str:
    path = Path(path_value)
    if not path.is_absolute():
        return path.as_posix()
    try:
        return path.relative_to(REPO_ROOT).as_posix()
    except ValueError:
        pass
    if path_value.startswith("/tmp/"):
        return path.relative_to("/").as_posix()
    raise SystemExit(
        f"Path must be repo-relative or under /tmp for RunPod bundling: {path_value}"
    )


def sync_commands_for_tmp_path(path_value: str, bundle_path: str) -> list[str]:
    if not Path(path_value).is_absolute() or not path_value.startswith("/tmp/"):
        return []
    return [
        f"mkdir -p {shlex.quote(str(Path(path_value).parent))}",
        f"rm -rf {shlex.quote(path_value)}",
        f"cp -R {shlex.quote(bundle_path)} {shlex.quote(path_value)}",
    ]


def downloaded_results_dir(local_results_path: str, results_path: str) -> Path:
    return Path(local_results_path) / Path(results_path).name


def aggregate_summary_path(local_results_path: str, results_path: str) -> Path:
    return (
        downloaded_results_dir(local_results_path, results_path)
        / DEFAULT_RESULT_SUMMARY_NAME
    )


def clear_downloaded_results_dir(local_results_path: str, results_path: str) -> None:
    shutil.rmtree(
        downloaded_results_dir(local_results_path, results_path), ignore_errors=True
    )


def load_aggregate_summary(local_results_path: str, results_path: str) -> dict:
    summary_path = aggregate_summary_path(local_results_path, results_path)
    if not summary_path.exists():
        raise SystemExit(
            f"Missing downloaded budget sweep aggregate summary: {summary_path}"
        )
    try:
        payload = json.loads(summary_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as error:
        raise SystemExit(
            f"Invalid downloaded budget sweep aggregate summary: {summary_path}"
        ) from error
    if not isinstance(payload, dict) or not isinstance(payload.get("passed"), bool):
        raise SystemExit(
            f"Downloaded budget sweep aggregate summary must contain boolean 'passed': {summary_path}"
        )
    payload["aggregate_summary_path"] = str(summary_path)
    return payload


def build_output_payload(result: dict, summary: dict) -> dict:
    return {
        "pod_id": result.get("pod_id"),
        "bundle_path": result.get("bundle_path"),
        "delete_command": (result.get("shell_plan") or {}).get("delete_command"),
        "experiment_report_path": result.get("experiment_report_path"),
        "experiment_passed": result.get("experiment_passed"),
        "manifest_path": result.get("manifest_path"),
        "manifest_status": result.get("manifest_status"),
        "aggregate_summary_path": summary["aggregate_summary_path"],
        "sweep_passed": summary["passed"],
        "lanes": summary.get("lanes"),
    }


def main() -> int:
    args = parser.parse_args()

    dry_run_candidate_path = args.candidate_path
    dry_run_current_path = args.current_path
    if Path(args.candidate_path).is_absolute() and not args.candidate_path.startswith(
        "/tmp/"
    ):
        dry_run_candidate_path = str(
            REPO_ROOT / stage_absolute_bundle_path(args.candidate_path)
        )
        candidate_bundle_path = (
            Path(dry_run_candidate_path).relative_to(REPO_ROOT).as_posix()
        )
    else:
        candidate_bundle_path = repo_bundle_path(args.candidate_path)

    if Path(args.current_path).is_absolute() and not args.current_path.startswith(
        "/tmp/"
    ):
        dry_run_current_path = str(
            REPO_ROOT / stage_absolute_bundle_path(args.current_path)
        )
        current_bundle_path = (
            Path(dry_run_current_path).relative_to(REPO_ROOT).as_posix()
        )
    elif Path(args.current_path).is_absolute():
        current_bundle_path = repo_bundle_path(args.current_path)
    else:
        current_bundle_path = args.current_path

    include_paths = [
        "script/ai/superhuman_budget_sweep",
        "script/ai/local_promotion_gate",
        "script/ai/check_superhuman_regressions",
        "ml/alphazero_lite",
        "model-artifact/current",
        candidate_bundle_path,
        "test/fixtures/ai/superhuman_regression_positions.json",
    ]
    if args.current_path != "model-artifact/current":
        include_paths.append(current_bundle_path)

    sweep_command = " ".join(
        [
            "script/ai/superhuman_budget_sweep",
            f"--candidate-path {shlex.quote(dry_run_candidate_path)}",
            f"--current-path {shlex.quote(dry_run_current_path)}",
            f"--simulations {shlex.quote(args.simulations)}",
            f"--output-root {shlex.quote(args.output_root)}",
        ]
    )

    command = " && ".join(
        [
            f"mkdir -p {shlex.quote(args.results_path)}",
            *sync_commands_for_tmp_path(args.candidate_path, candidate_bundle_path),
            *sync_commands_for_tmp_path(args.current_path, current_bundle_path),
            " ".join(
                [
                    "(",
                    f"if {sweep_command};",
                    "then sweep_status=0;",
                    "else sweep_status=$?;",
                    f"fi; if cp -R {shlex.quote(args.output_root)}/. {shlex.quote(args.results_path)}/;",
                    "then copy_status=0;",
                    "else copy_status=$?;",
                    'fi; if [ "$copy_status" -ne 0 ]; then exit "$copy_status"; fi;',
                    'exit "$sweep_status"',
                    ")",
                ]
            ),
        ]
    )

    include_paths = list(dict.fromkeys(include_paths))
    if args.dry_run:
        plan = build_dry_run_plan(
            name=args.name,
            command=command,
            bundle_path=args.bundle_path,
            results_path=args.results_path,
            local_results_path=args.local_results_path,
            include_paths=include_paths,
            api_key_env=args.api_key_env,
            pod_profile=args.pod_profile,
            run_timeout_seconds=args.run_timeout_seconds,
            keep_pod_on_failure=args.keep_pod_on_failure,
        )
        print(json.dumps(plan, indent=2))
        return 0

    if Path(args.candidate_path).is_absolute() and not args.candidate_path.startswith(
        "/tmp/"
    ):
        candidate_bundle_path = stage_absolute_bundle_path(args.candidate_path)
    else:
        candidate_bundle_path = stage_tmp_bundle_path(args.candidate_path)
    current_bundle_path = (
        stage_tmp_bundle_path(args.current_path)
        if Path(args.current_path).is_absolute()
        else args.current_path
    )
    if Path(args.current_path).is_absolute() and not args.current_path.startswith(
        "/tmp/"
    ):
        current_bundle_path = stage_absolute_bundle_path(args.current_path)

    include_paths = [
        "script/ai/superhuman_budget_sweep",
        "script/ai/local_promotion_gate",
        "script/ai/check_superhuman_regressions",
        "ml/alphazero_lite",
        "model-artifact/current",
        candidate_bundle_path,
        "test/fixtures/ai/superhuman_regression_positions.json",
    ]
    if args.current_path != "model-artifact/current":
        include_paths.append(current_bundle_path)
    include_paths = list(dict.fromkeys(include_paths))

    clear_downloaded_results_dir(args.local_results_path, args.results_path)

    result = None
    orchestrate_error = None
    try:
        result = orchestrate(
            name=args.name,
            command=command,
            bundle_path=args.bundle_path,
            results_path=args.results_path,
            local_results_path=args.local_results_path,
            include_paths=include_paths,
            api_key_env=args.api_key_env,
            pod_profile=args.pod_profile,
            run_timeout_seconds=args.run_timeout_seconds,
            keep_pod_on_failure=args.keep_pod_on_failure,
        )
    except Exception as error:
        orchestrate_error = error

    try:
        summary = load_aggregate_summary(args.local_results_path, args.results_path)
    except SystemExit:
        if orchestrate_error is not None:
            raise orchestrate_error
        raise

    print(json.dumps(build_output_payload(result or {}, summary), indent=2))
    if summary["passed"]:
        return 0
    return 1


parser = argparse.ArgumentParser(
    prog="script/ai/runpod_superhuman_budget_sweep",
    description="Launch a RunPod search-budget sweep for the superhuman phase2 candidate.",
)
parser.add_argument("--candidate-path", default=DEFAULT_CANDIDATE_PATH)
parser.add_argument("--current-path", default=DEFAULT_CURRENT_PATH)
parser.add_argument("--simulations", default=DEFAULT_SIMULATIONS)
parser.add_argument("--output-root", default=DEFAULT_OUTPUT_ROOT)
parser.add_argument("--results-path", default=DEFAULT_RESULTS_PATH)
parser.add_argument("--local-results-path", default=DEFAULT_LOCAL_RESULTS_PATH)
parser.add_argument("--bundle-path", default=DEFAULT_BUNDLE_PATH)
parser.add_argument("--api-key-env", default="RUNPOD_API_KEY")
parser.add_argument("--name", default=DEFAULT_NAME)
parser.add_argument("--pod-profile", default=DEFAULT_POD_PROFILE)
parser.add_argument("--run-timeout-seconds", type=int, default=14400)
parser.add_argument(
    "--keep-pod-on-failure", action=argparse.BooleanOptionalAction, default=True
)
parser.add_argument("--dry-run", action="store_true")


if __name__ == "__main__":
    raise SystemExit(main())
