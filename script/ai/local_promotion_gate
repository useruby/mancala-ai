def load_json(path: Path) -> dict:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise SystemExit(f"invalid JSON in stub report: {path}") from exc


def resolve_optional_config_path(config_path: str | None) -> Path | None:
    if not config_path:
        return None
    path = Path(config_path)
    if not path.is_absolute():
        path = repo_root() / path
    if not path.exists():
        raise SystemExit(f"config path does not exist: {config_path}")
    return path


def search_flags_for_step(config: dict, step_name: str, *, required: bool) -> list[str]:
    step = next(
        (
            candidate
            for candidate in config.get("steps", [])
            if candidate.get("name") == step_name
        ),
        None,
    )
    if step is None:
        if required:
            raise SystemExit(f"config missing required step: {step_name}")
        return []

    command = step.get("command", [])
    rendered_flags: list[str] = []
    option_flags = ("--fpu-mode", "--root-policy-mode", "--tactical-root-bias")
    boolean_flags = ("--reuse-subtree", "--normalize-values")

    for flag in option_flags:
        if flag in command:
            flag_index = command.index(flag)
            if flag_index + 1 >= len(command):
                raise SystemExit(f"config step {step_name} missing value for {flag}")
            rendered_flags.extend([flag, command[flag_index + 1]])

    for flag in boolean_flags:
        if flag in command:
            rendered_flags.append(flag)

    return rendered_flags


def load_search_flag_map(
    config_path: str | None, *, require_steps: bool = True
) -> dict[str, list[str]]:
    resolved_path = resolve_optional_config_path(config_path)
    if resolved_path is None:
        return {}

    config = load_json(resolved_path)
    present_step_names = {
        step.get("name")
        for step in config.get("steps", [])
        if isinstance(step, dict) and isinstance(step.get("name"), str)
    }
    require_mcts_steps = require_steps and any(
        step_name in present_step_names
        for step_name in (
            "mcts1200_baseline_report",
            "current_mcts1200_baseline_report",
        )
    )

    return {
        "arena": search_flags_for_step(config, "arena_confirm_report", required=False),
        "candidate_mcts": search_flags_for_step(
            config, "mcts1200_baseline_report", required=require_mcts_steps
        ),
        "current_mcts": search_flags_for_step(
            config, "current_mcts1200_baseline_report", required=require_mcts_steps
        ),
    }


def load_threshold_planning_search_flag_map(
    config_path: str | None,
) -> dict[str, list[str]]:
    return load_search_flag_map(config_path, require_steps=False)


