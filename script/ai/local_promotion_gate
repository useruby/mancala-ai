def numeric_metric(payload: dict, key: str, *, context: str) -> float:
    if not isinstance(payload, dict):
        raise SystemExit(f"malformed forensic payload for {context}: expected object")

    value = payload.get(key)
    if isinstance(value, bool) or not isinstance(value, (int, float)):
        raise SystemExit(
            f"malformed forensic metric {context}.{key}: expected numeric value"
        )

    if not math.isfinite(float(value)):
        raise SystemExit(
            f"malformed forensic metric {context}.{key}: non-finite numeric value"
        )

    numeric_value = float(value)

    if key in ("top1_agreement", "blunder_rate") and not 0.0 <= numeric_value <= 1.0:
        raise SystemExit(
            f"malformed forensic metric {context}.{key}: expected value between 0.0 and 1.0"
        )

    if key == "average_regret" and numeric_value < 0.0:
        raise SystemExit(
            f"malformed forensic metric {context}.{key}: expected value greater than or equal to 0.0"
        )

    return numeric_value


def forensic_metric_block(payload: dict, *, context: str) -> dict[str, float]:
    if not isinstance(payload, dict):
        raise SystemExit(
            f"malformed forensic metric block for {context}: expected object"
        )

    return {
        metric_name: numeric_metric(payload, metric_name, context=context)
        for metric_name in FORENSIC_METRICS
    }


def forensic_system_overall(report: dict, system_name: str) -> dict[str, float]:
    if not isinstance(report, dict):
        raise SystemExit("malformed forensic report: expected object")

    systems = report.get("systems")
    if not isinstance(systems, dict):
        raise SystemExit("malformed forensic report: missing systems block")

    system_payload = systems.get(system_name)
    if not isinstance(system_payload, dict):
        raise SystemExit(
            f"malformed forensic report: missing systems.{system_name} block"
        )

    overall = system_payload.get("overall")
    if not isinstance(overall, dict):
        raise SystemExit(
            f"malformed forensic report: missing systems.{system_name}.overall block"
        )

    return forensic_metric_block(overall, context=f"systems.{system_name}.overall")


def forensic_bucket_metrics(
    report: dict, bucket_name: str, system_name: str
) -> dict[str, float]:
    if not isinstance(report, dict):
        raise SystemExit("malformed forensic report: expected object")

    buckets = report.get("buckets")
    if not isinstance(buckets, dict):
        raise SystemExit("malformed forensic report: missing buckets block")

    bucket_payload = buckets.get(bucket_name)
    if not isinstance(bucket_payload, dict):
        raise SystemExit(f"missing required forensic bucket: {bucket_name}")

    systems = bucket_payload.get("systems")
    if not isinstance(systems, dict):
        raise SystemExit(
            f"malformed forensic bucket {bucket_name}: missing systems block"
        )

    system_payload = systems.get(system_name)
    if not isinstance(system_payload, dict):
        raise SystemExit(
            f"malformed forensic bucket {bucket_name}: missing systems.{system_name} block"
        )

    return forensic_metric_block(
        system_payload, context=f"buckets.{bucket_name}.systems.{system_name}"
    )


def forensic_quality_summary(report: dict) -> dict:
    if not isinstance(report, dict):
        raise SystemExit("malformed forensic report: expected object")

    if report.get("schema") != "azlite_forensic_suite_v1":
        raise SystemExit(
            "malformed forensic report: expected schema azlite_forensic_suite_v1"
        )

    return {
        "overall": {
            "current": forensic_system_overall(report, "current"),
            "challenger": forensic_system_overall(report, "challenger"),
        },
        "critical_buckets": {
            bucket_name: {
                "current": forensic_bucket_metrics(report, bucket_name, "current"),
                "challenger": forensic_bucket_metrics(
                    report, bucket_name, "challenger"
                ),
            }
            for bucket_name in CRITICAL_FORENSIC_BUCKETS
        },
    }


def raw_metric_delta(*, challenger: float, current: float) -> float:
    return challenger - current


def evaluate_forensic_quality(report: dict) -> dict:
    summary = forensic_quality_summary(report)
    failure_reasons = []

    def evaluate_metric(
        metric_name: str, challenger: float, current: float, threshold: float
    ) -> dict:
        raw_delta = raw_metric_delta(challenger=challenger, current=current)
        delta = round(raw_delta, 4)
        if metric_name == "top1_agreement":
            passed = raw_delta >= threshold
        else:
            passed = raw_delta <= threshold

        return {
            "challenger": challenger,
            "current": current,
            "delta": delta,
            "threshold": threshold,
            "passed": passed,
        }

    overall_metrics = {}
    overall_passed = True
    for metric_name, threshold in FORENSIC_THRESHOLDS["overall"].items():
        metric_report = evaluate_metric(
            metric_name,
            summary["overall"]["challenger"][metric_name],
            summary["overall"]["current"][metric_name],
            threshold,
        )
        overall_metrics[metric_name] = metric_report
        overall_passed = overall_passed and metric_report["passed"]
    if not overall_passed:
        failure_reasons.append({"code": "forensic_overall_regressed"})

    bucket_reports = {}
    for bucket_name, thresholds in FORENSIC_THRESHOLDS["critical_buckets"].items():
        bucket_metrics = {}
        bucket_passed = True
        for metric_name, threshold in thresholds.items():
            metric_report = evaluate_metric(
                metric_name,
                summary["critical_buckets"][bucket_name]["challenger"][metric_name],
                summary["critical_buckets"][bucket_name]["current"][metric_name],
                threshold,
            )
            bucket_metrics[metric_name] = metric_report
            bucket_passed = bucket_passed and metric_report["passed"]

        bucket_reports[bucket_name] = {
            **bucket_metrics,
            "passed": bucket_passed,
        }
        if not bucket_passed:
            failure_reasons.append({"code": f"forensic_bucket_{bucket_name}_regressed"})

    return {
        "passed": not failure_reasons,
        "overall": {
            **overall_metrics,
            "passed": overall_passed,
        },
        "critical_buckets": bucket_reports,
        "failure_reasons": failure_reasons,
    }


def build_endgame_exact_solve_section(
    *, status: str, results_source: str, results: list[dict]
) -> dict:
    return {
        "status": status,
        "scaffold_only": True,
        "results_source": results_source,
        "thresholds": [8, 10, 12],
        "results": results,
        "planned_evaluations": [],
        "recommendation": {
            "enabled": False,
            "threshold": None,
            "reason": "endgame exact solve threshold data is scaffold metadata only until threshold-specific evaluations run",
        },
    }


def build_endgame_exact_solve_recommendation(results: list[dict]) -> dict:
    if not results:
        return {
            "enabled": False,
            "threshold": None,
            "reason": "endgame exact solve threshold data is scaffold metadata only until threshold-specific evaluations run",
        }

    best_result = max(
        results,
        key=lambda row: (
            float(row.get("candidate_mcts_score", 0.0))
            - float(row.get("current_mcts_score", 0.0)),
            float(row.get("candidate_mcts_score", 0.0)),
            -int(row.get("threshold", 0)),
        ),
    )
    best_gain = round(
        float(best_result.get("candidate_mcts_score", 0.0))
        - float(best_result.get("current_mcts_score", 0.0)),
        4,
    )
    if best_gain <= 0.0:
        return {
            "enabled": False,
            "threshold": None,
            "reason": "no threshold improved candidate-vs-mcts1200 score over the current baseline",
        }

    return {
        "enabled": True,
        "threshold": int(best_result["threshold"]),
        "reason": f"threshold {int(best_result['threshold'])} delivered the best candidate-vs-mcts1200 gain ({best_gain:+.4f})",
    }


def build_endgame_exact_solve_plans(
    args: argparse.Namespace, *, report_dir: Path, search_flag_map: dict[str, list[str]]
) -> list[dict]:
    plans = []
    for threshold in (8, 10, 12):
        candidate_report_path = (
            report_dir
            / f"endgame_exact_solve_threshold_{threshold}_candidate_vs_mcts1200.json"
        )
        current_report_path = (
            report_dir
            / f"endgame_exact_solve_threshold_{threshold}_current_vs_mcts1200.json"
        )
        summary_report_path = (
            report_dir / f"endgame_exact_solve_threshold_{threshold}.json"
        )
        plans.append(
            {
                "threshold": threshold,
                "status": "planned",
                "scaffold_only": True,
                "mode": "planned",
                "report_path": str(summary_report_path),
                "candidate_mcts_report_path": str(candidate_report_path),
                "current_mcts_report_path": str(current_report_path),
                "candidate_mcts_command": [
                    python_executable(),
                    "ml/alphazero_lite/mcts1200_baseline.py",
                    "--challenger-path",
                    str(args.candidate_path),
                    "--games",
                    str(args.mcts_games),
                    *search_flag_map.get("candidate_mcts", []),
                    "--exact-solve-enabled",
                    "--exact-solve-stone-threshold",
                    str(threshold),
                    "--out",
                    str(candidate_report_path),
                ],
                "current_mcts_command": [
                    python_executable(),
                    "ml/alphazero_lite/mcts1200_baseline.py",
                    "--challenger-path",
                    str(args.current_path),
                    "--games",
                    str(args.mcts_games),
                    *search_flag_map.get("current_mcts", []),
                    "--exact-solve-enabled",
                    "--exact-solve-stone-threshold",
                    str(threshold),
                    "--out",
                    str(current_report_path),
                ],
            }
        )
    return plans


def build_decision_report(
    args: argparse.Namespace,
    report: dict,
    *,
    arena_report: dict,
    hard_report: dict | None,
    candidate_mcts_report: dict,
    current_mcts_report: dict,
    regression_report: dict,
    forensic_report: dict | None,
    arena_report_path: Path,
    hard_report_path: Path | None,
    candidate_mcts_report_path: Path,
    current_mcts_report_path: Path,
    regression_report_path: Path,
) -> dict:
    planned_evaluations = list(
        report.get("endgame_exact_solve", {}).get("planned_evaluations", [])
    )
    existing_threshold_results = list(
        report.get("endgame_exact_solve", {}).get("results", [])
    )
    arena_games_played = int(arena_report.get("games_played", 0))
    arena_losses = int(arena_report.get("losses", 0))
    candidate_mcts_games = int(candidate_mcts_report.get("games", 0))
    current_mcts_games = int(current_mcts_report.get("games", 0))

    raw_arena_score = arena_score(arena_report)
    raw_candidate_mcts_score = mcts_score(candidate_mcts_report)
    raw_current_mcts_score = mcts_score(current_mcts_report)

    computed_arena_score = round(raw_arena_score, 4)
    computed_candidate_mcts_score = round(raw_candidate_mcts_score, 4)
    computed_current_mcts_score = round(raw_current_mcts_score, 4)

    failure_reasons = []
    if arena_games_played < args.min_arena_games:
        failure_reasons.append({"code": "arena_games_below_minimum"})
    if candidate_mcts_games < args.min_mcts_games:
        failure_reasons.append({"code": "candidate_mcts_games_below_minimum"})
    if current_mcts_games < args.min_mcts_games:
        failure_reasons.append({"code": "current_mcts_games_below_minimum"})
    if raw_arena_score < args.min_arena_score:
        failure_reasons.append({"code": "arena_score_below_threshold"})
    if args.require_lossless and arena_losses > args.max_losses:
        failure_reasons.append({"code": "arena_losses_above_threshold"})
    if (
        not args.skip_mcts_relative_check
        and raw_candidate_mcts_score < raw_current_mcts_score
    ):
        failure_reasons.append({"code": "candidate_mcts_below_current"})
    if not regression_report.get("passed", False):
        failure_reasons.append({"code": "regression_check_failed"})

    forensic_quality = (
        evaluate_forensic_quality(forensic_report)
        if forensic_report is not None
        else None
    )
    if forensic_quality is not None and not forensic_quality["passed"]:
        failure_reasons.extend(forensic_quality["failure_reasons"])

    notes = (
        arena_report.get("notes", {})
        if isinstance(arena_report.get("notes", {}), dict)
        else {}
    )
    move_time_mean_ms = notes.get(
        "move_time_mean_ms", arena_report.get("move_time_mean_ms")
    )
    move_time_p95_ms = notes.get(
        "move_time_p95_ms", arena_report.get("move_time_p95_ms")
    )
    if args.max_arena_move_time_mean_ms is not None:
        if move_time_mean_ms is None:
            failure_reasons.append({"code": "arena_move_time_mean_missing"})
        elif float(move_time_mean_ms) > args.max_arena_move_time_mean_ms:
            failure_reasons.append({"code": "arena_move_time_mean_above_threshold"})
    if args.max_arena_move_time_p95_ms is not None:
        if move_time_p95_ms is None:
            failure_reasons.append({"code": "arena_move_time_p95_missing"})
        elif float(move_time_p95_ms) > args.max_arena_move_time_p95_ms:
            failure_reasons.append({"code": "arena_move_time_p95_above_threshold"})

    computed_hard_score: float | None = None
    if hard_report is not None:
        hard_games_played = int(hard_report.get("games_played", 0))
        raw_hard_score = arena_score(hard_report)
        computed_hard_score = round(raw_hard_score, 4)
        if hard_games_played < args.hard_arena_games:
            failure_reasons.append({"code": "hard_games_below_minimum"})
        if raw_hard_score < args.hard_min_score:
            failure_reasons.append({"code": "candidate_not_stronger_than_hard"})

    report.update(
        {
            "arena_report_path": str(arena_report_path),
            "hard_report_path": str(hard_report_path)
            if hard_report_path is not None
            else None,
            "candidate_mcts_report_path": str(candidate_mcts_report_path),
            "current_mcts_report_path": str(current_mcts_report_path),
            "regression_report_path": str(regression_report_path),
            "arena_score": computed_arena_score,
            "hard_score": computed_hard_score,
            "arena_losses": arena_losses,
            "candidate_mcts_score": computed_candidate_mcts_score,
            "current_mcts_score": computed_current_mcts_score,
            "dynamic_budget": dynamic_budget_summary(
                candidate_mcts_report, current_mcts_report, arena_report
            ),
            "hard_suite_buckets": hard_suite_bucket_breakdown(hard_report),
            "forensic_quality": forensic_quality,
            "lossless_passed": arena_losses <= args.max_losses,
            "passed": not failure_reasons,
            "failure_reasons": failure_reasons,
            "endgame_exact_solve": build_endgame_exact_solve_section(
                status="executed" if existing_threshold_results else "planned_only",
                results_source="threshold_specific_reports"
                if existing_threshold_results
                else "planned_evaluation_metadata_only",
                results=existing_threshold_results,
            ),
        }
    )
    report["dynamic_budget_recommendation"] = build_dynamic_budget_recommendation(
        passed=report["passed"],
        arena_score_value=computed_arena_score,
        candidate_mcts_score_value=computed_candidate_mcts_score,
        current_mcts_score_value=computed_current_mcts_score,
        dynamic_budget=report["dynamic_budget"],
        failure_reasons=failure_reasons,
    )
    dynamic_budget_details = report.get("dynamic_budget")
    opening_cache_summary = None
    if isinstance(dynamic_budget_details, dict):
        opening_cache_summary = dynamic_budget_details.get("opening_cache_summary")
    report["opening_cache_recommendation"] = build_opening_cache_recommendation(
        opening_cache_summary=opening_cache_summary
    )
    report["endgame_exact_solve"]["planned_evaluations"] = planned_evaluations
    report["endgame_exact_solve"]["scaffold_only"] = not bool(
        existing_threshold_results
    )
    report["endgame_exact_solve"]["recommendation"] = (
        build_endgame_exact_solve_recommendation(existing_threshold_results)
    )
    return report


