def run_command(command: list[str]) -> None:
    result = subprocess.run(
        command,
        cwd=repo_root(),
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        details = (result.stderr or result.stdout).strip()
        command_label = Path(command[1]).name if len(command) > 1 else command[0]
        if details:
            raise SystemExit(f"{command_label} failed: {details}")
        raise SystemExit(f"{command_label} failed: {' '.join(command)}")


def run_regression_check(command: list[str], report_path: Path) -> dict:
    if report_path.exists():
        report_path.unlink()
    command_with_output = [*command, "--out", str(report_path)]
    result = subprocess.run(
        command_with_output,
        cwd=repo_root(),
        capture_output=True,
        text=True,
        check=False,
    )

    stdout = result.stdout.strip()
    if result.returncode not in (0, 1):
        details = (result.stderr or stdout).strip()
        if details:
            raise SystemExit(f"check_superhuman_regressions failed: {details}")
        raise SystemExit("check_superhuman_regressions failed")
    report_text = (
        report_path.read_text(encoding="utf-8").strip()
        if report_path.exists()
        else stdout
    )

    try:
        report = json.loads(report_text)
    except json.JSONDecodeError as exc:
        details = (result.stderr or report_text or stdout).strip()
        if details:
            raise SystemExit(f"check_superhuman_regressions failed: {details}") from exc
        raise SystemExit("check_superhuman_regressions failed") from exc

    if not isinstance(report, dict) or "passed" not in report:
        raise SystemExit("check_superhuman_regressions failed: missing passed field")

    return report


def build_real_decision_report(args: argparse.Namespace, report: dict) -> dict:
    evaluations = {evaluation["id"]: evaluation for evaluation in report["evaluations"]}
    arena_report_path = Path(evaluations["candidate_vs_current_arena"]["report_path"])
    candidate_mcts_report_path = Path(
        evaluations["candidate_vs_mcts1200"]["report_path"]
    )
    current_mcts_report_path = Path(evaluations["current_vs_mcts1200"]["report_path"])
    hard_report_path = (
        Path(evaluations["candidate_vs_hard_arena"]["report_path"])
        if "candidate_vs_hard_arena" in evaluations
        else None
    )
    forensic_report_path = Path(evaluations["candidate_forensic_suite"]["report_path"])
    regression_report_path = Path(report["regression_report_path"])
    search_flag_map = load_search_flag_map(args.config_path)

    run_command(
        [
            python_executable(),
            "ml/alphazero_lite/arena.py",
            "--challenger",
            str(args.candidate_path),
            "--current",
            str(args.current_path),
            "--games",
            str(args.arena_games),
            *search_flag_map.get("arena", []),
            "--min-score",
            str(args.min_arena_score),
            "--out",
            str(arena_report_path),
        ]
    )
    arena_report = load_json(arena_report_path)
    prefilter_failure_reasons = computed_arena_prefilter_threshold_failures(
        args, arena_report
    )
    promotion_decision = arena_report.get("promotion_decision")
    promotion_decision_passed = (
        isinstance(promotion_decision, dict)
        and isinstance(promotion_decision.get("passed"), bool)
        and promotion_decision["passed"]
    )
    if prefilter_failure_reasons or not promotion_decision_passed:
        for evaluation in report["evaluations"]:
            evaluation["mode"] = (
                "executed"
                if evaluation["id"] == "candidate_vs_current_arena"
                else "not_produced"
            )
        for planned_evaluation in report["endgame_exact_solve"]["planned_evaluations"]:
            planned_evaluation["status"] = "not_produced"
            planned_evaluation["mode"] = "not_produced"
            planned_evaluation["scaffold_only"] = True
        report.update(
            {
                "arena_report_path": str(arena_report_path),
                "hard_report_path": None,
                "candidate_mcts_report_path": None,
                "current_mcts_report_path": None,
                "regression_report_path": None,
                "forensic_report_path": None,
                "arena_score": round(arena_score(arena_report), 4),
                "hard_score": None,
                "arena_losses": int(arena_report.get("losses", 0)),
                "candidate_mcts_score": None,
                "current_mcts_score": None,
                "dynamic_budget": None,
                "hard_suite_buckets": None,
                "forensic_quality": None,
                "lossless_passed": int(arena_report.get("losses", 0))
                <= args.max_losses,
                "passed": False,
                "failure_reasons": arena_prefilter_failure_reasons(args, arena_report),
            }
        )
        report["endgame_exact_solve"]["status"] = "not_produced"
        report["endgame_exact_solve"]["results_source"] = (
            "skipped_due_to_arena_prefilter"
        )
        report["dynamic_budget_recommendation"] = build_dynamic_budget_recommendation(
            passed=False,
            arena_score_value=report["arena_score"],
            candidate_mcts_score_value=0.0,
            current_mcts_score_value=0.0,
            dynamic_budget=None,
            failure_reasons=report["failure_reasons"],
        )
        report["opening_cache_recommendation"] = build_opening_cache_recommendation(
            opening_cache_summary=None
        )
        return report
    if args.hard_path is not None:
        run_command(
            [
                python_executable(),
                "ml/alphazero_lite/arena.py",
                "--challenger",
                str(args.candidate_path),
                "--current",
                str(args.hard_path),
                "--games",
                str(args.hard_arena_games),
                *search_flag_map.get("arena", []),
                "--min-score",
                str(args.hard_min_score),
                "--out",
                str(hard_report_path),
            ]
        )
    run_command(
        [
            python_executable(),
            "ml/alphazero_lite/mcts1200_baseline.py",
            "--challenger-path",
            str(args.candidate_path),
            "--games",
            str(args.mcts_games),
            *search_flag_map.get("candidate_mcts", []),
            "--out",
            str(candidate_mcts_report_path),
        ]
    )
    run_command(
        [
            python_executable(),
            "ml/alphazero_lite/mcts1200_baseline.py",
            "--challenger-path",
            str(args.current_path),
            "--games",
            str(args.mcts_games),
            *search_flag_map.get("current_mcts", []),
            "--out",
            str(current_mcts_report_path),
        ]
    )
    run_command(evaluations["candidate_forensic_suite"]["command"])
    regression_report = run_regression_check(
        [
            python_executable(),
            "script/ai/check_superhuman_regressions",
            "--artifact",
            str(args.candidate_path),
            "--positions",
            str(args.regression_positions_path),
            *search_flag_map.get("arena", []),
        ],
        regression_report_path,
    )

    threshold_results = []
    for planned_evaluation in report["endgame_exact_solve"]["planned_evaluations"]:
        run_command(planned_evaluation["candidate_mcts_command"])
        run_command(planned_evaluation["current_mcts_command"])
        candidate_threshold_report = load_json(
            Path(planned_evaluation["candidate_mcts_report_path"])
        )
        current_threshold_report = load_json(
            Path(planned_evaluation["current_mcts_report_path"])
        )
        threshold_summary = {
            "threshold": int(planned_evaluation["threshold"]),
            "mode": "executed",
            "score": round(mcts_score(candidate_threshold_report), 4),
            "candidate_mcts_score": round(mcts_score(candidate_threshold_report), 4),
            "current_mcts_score": round(mcts_score(current_threshold_report), 4),
            "candidate_mcts_report_path": planned_evaluation[
                "candidate_mcts_report_path"
            ],
            "current_mcts_report_path": planned_evaluation["current_mcts_report_path"],
        }
        Path(planned_evaluation["report_path"]).write_text(
            json.dumps(threshold_summary, indent=2), encoding="utf-8"
        )
        planned_evaluation["status"] = "executed"
        planned_evaluation["mode"] = "executed"
        planned_evaluation["scaffold_only"] = False
        threshold_results.append(threshold_summary)

    report["endgame_exact_solve"]["results"] = threshold_results

    for evaluation in report["evaluations"]:
        evaluation["mode"] = "executed"

    hard_report = load_json(hard_report_path) if hard_report_path is not None else None
    return build_decision_report(
        args,
        report,
        arena_report=arena_report,
        hard_report=hard_report,
        candidate_mcts_report=load_json(candidate_mcts_report_path),
        current_mcts_report=load_json(current_mcts_report_path),
        regression_report=regression_report,
        forensic_report=load_json(forensic_report_path),
        arena_report_path=arena_report_path,
        hard_report_path=hard_report_path,
        candidate_mcts_report_path=candidate_mcts_report_path,
        current_mcts_report_path=current_mcts_report_path,
        regression_report_path=regression_report_path,
    )


def main() -> int:
    args = parse_args()
    args.out.parent.mkdir(parents=True, exist_ok=True)
    if args.dry_run and args.config_path:
        load_threshold_planning_search_flag_map(args.config_path)
    if not args.dry_run and args.config_path:
        load_search_flag_map(args.config_path)

    required_stub_paths = (
        args.stub_arena_report,
        args.stub_candidate_mcts_report,
        args.stub_current_mcts_report,
        args.stub_forensic_report,
    )
    all_stub_paths = (
        args.stub_arena_report,
        args.stub_candidate_mcts_report,
        args.stub_current_mcts_report,
        args.stub_regression_report,
        args.stub_forensic_report,
    )
    if args.stub_forensic_report is not None and not all(
        path is not None for path in required_stub_paths[:-1]
    ):
        raise SystemExit("--stub-forensic-report requires full stub bundle")
    if any(path is not None for path in all_stub_paths) and not all(
        path is not None for path in required_stub_paths
    ):
        raise SystemExit(
            "provide arena, candidate/current mcts, and forensic stub report paths together or none"
