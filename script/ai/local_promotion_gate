            search_flag_map=search_flag_map,
        )
    )

    stub_reports_provided = all(path is not None for path in required_stub_paths)

    if stub_reports_provided:
        if args.stub_regression_report is not None:
            report["regression_report_path"] = str(args.stub_regression_report)
        report["forensic_report_path"] = str(args.stub_forensic_report)
        report = build_stub_decision_report(args, report)
    elif not args.dry_run:
        report = build_real_decision_report(args, report)

    args.out.write_text(json.dumps(report, indent=2), encoding="utf-8")
    print(json.dumps({"report_path": str(args.out), "dry_run": args.dry_run}))
    if not args.dry_run and not report.get("passed", True):
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
