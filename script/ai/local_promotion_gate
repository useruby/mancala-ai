#!/usr/bin/env python3
import argparse
import json
from pathlib import Path
import subprocess
import sys


def positive_int(value: str) -> int:
    parsed = int(value)
    if parsed <= 0:
        raise argparse.ArgumentTypeError("must be a positive integer")
    return parsed


def non_negative_int(value: str) -> int:
    parsed = int(value)
    if parsed < 0:
        raise argparse.ArgumentTypeError("must be a non-negative integer")
    return parsed


def existing_path(value: str) -> Path:
    path = Path(value)
    if not path.exists():
        raise argparse.ArgumentTypeError(f"path does not exist: {value}")
    return path


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Write a local AlphaZero-lite promotion gate dry-run plan."
    )
    parser.add_argument("--candidate-path", required=True, type=existing_path)
    parser.add_argument(
        "--config-path",
        help="optional pipeline config path to record in the report for local ablation runs",
    )
    parser.add_argument(
        "--current-path",
        default="model-artifact/current",
    )
    parser.add_argument(
        "--hard-path",
        default="model-artifact/current",
    )
    parser.add_argument(
        "--regression-positions-path",
        default="test/fixtures/ai/superhuman_regression_positions.json",
    )
    parser.add_argument("--arena-games", default=120, type=positive_int)
    parser.add_argument("--mcts-games", default=40, type=positive_int)
    parser.add_argument("--min-arena-score", default=0.55, type=float)
    parser.add_argument("--min-arena-games", default=120, type=positive_int)
    parser.add_argument("--min-mcts-games", default=40, type=positive_int)
    parser.add_argument("--hard-arena-games", default=120, type=positive_int)
    parser.add_argument("--hard-min-score", default=0.55, type=float)
    parser.add_argument("--max-arena-move-time-mean-ms", default=None, type=float)
    parser.add_argument("--max-arena-move-time-p95-ms", default=None, type=float)
    parser.add_argument("--require-lossless", action="store_true")
    parser.add_argument("--max-losses", default=0, type=non_negative_int)
    parser.add_argument("--skip-mcts-relative-check", action="store_true")
    parser.add_argument("--out", required=True, type=Path)
    parser.add_argument("--stub-arena-report", type=Path)
    parser.add_argument("--stub-hard-report", type=Path)
    parser.add_argument("--stub-candidate-mcts-report", type=Path)
    parser.add_argument("--stub-current-mcts-report", type=Path)
    parser.add_argument("--stub-regression-report", type=Path)
    parser.add_argument("--dry-run", action="store_true")
    return parser.parse_args()


def build_evaluation(*, evaluation_id: str, subject: str, opponent: str, games: int, report_dir: Path, mode: str) -> dict:
    return {
        "id": evaluation_id,
        "subject": subject,
        "opponent": opponent,
        "games": games,
        "mode": mode,
        "report_path": str(report_dir / f"{evaluation_id}.json"),
    }


def load_json(path: Path) -> dict:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise SystemExit(f"invalid JSON in stub report: {path}") from exc


def resolve_optional_config_path(config_path: str | None) -> Path | None:
    if not config_path:
        return None
    path = Path(config_path)
    if not path.is_absolute():
        path = repo_root() / path
    if not path.exists():
        raise SystemExit(f"config path does not exist: {config_path}")
    return path


def search_flags_for_step(config: dict, step_name: str, *, required: bool) -> list[str]:
    step = next((candidate for candidate in config.get("steps", []) if candidate.get("name") == step_name), None)
    if step is None:
        if required:
            raise SystemExit(f"config missing required step: {step_name}")
        return []

    command = step.get("command", [])
    rendered_flags: list[str] = []
    option_flags = ("--fpu-mode", "--root-policy-mode", "--tactical-root-bias")
    boolean_flags = ("--reuse-subtree", "--normalize-values")

    for flag in option_flags:
        if flag in command:
            flag_index = command.index(flag)
            if flag_index + 1 >= len(command):
                raise SystemExit(f"config step {step_name} missing value for {flag}")
            rendered_flags.extend([flag, command[flag_index + 1]])

    for flag in boolean_flags:
        if flag in command:
            rendered_flags.append(flag)

    return rendered_flags


def load_search_flag_map(config_path: str | None, *, require_steps: bool = True) -> dict[str, list[str]]:
    resolved_path = resolve_optional_config_path(config_path)
    if resolved_path is None:
        return {}

    config = load_json(resolved_path)
    return {
        "arena": search_flags_for_step(config, "arena_confirm_report", required=require_steps),
        "candidate_mcts": search_flags_for_step(config, "mcts1200_baseline_report", required=require_steps),
        "current_mcts": search_flags_for_step(config, "current_mcts1200_baseline_report", required=require_steps),
    }


def default_regression_report(positions_path: str) -> dict:
    return {
        "passed": True,
        "positions_path": positions_path,
        "results": [],
    }


def repo_root() -> Path:
    return Path(__file__).resolve().parents[2]


def python_executable() -> str:
    repo_python = repo_root() / ".venv/bin/python"
    if repo_python.exists():
        return str(repo_python)
    return sys.executable


def arena_score(report: dict) -> float:
    games_played = int(report.get("games_played", 0))
    if games_played <= 0:
        return 0.0
    wins = int(report.get("wins", 0))
    draws = int(report.get("draws", 0))
    return (wins + (0.5 * draws)) / games_played


def mcts_score(report: dict) -> float:
    games = int(report.get("games", 0))
    if games <= 0:
        return 0.0
    az_wins = int(report.get("az_wins", 0))
    draws = int(report.get("draws", 0))
    return (az_wins + (0.5 * draws)) / games


def dynamic_budget_summary(candidate_mcts_report: dict, current_mcts_report: dict, arena_report: dict) -> dict | None:
    candidate_budget = candidate_mcts_report.get("budget_summary", {})
    current_budget = current_mcts_report.get("budget_summary", {})
    arena_budget = arena_report.get("budget_summary", {})
    if not any((candidate_budget, current_budget, arena_budget)):
        return None

    return {
        "candidate_mean_final_simulations": candidate_budget.get("mean_final_simulations"),
        "candidate_mean_root_latency_ms": candidate_budget.get("mean_root_latency_ms"),
        "current_mean_final_simulations": current_budget.get("mean_final_simulations"),
        "current_mean_root_latency_ms": current_budget.get("mean_root_latency_ms"),
        "arena_trigger_counts": arena_budget.get("trigger_counts", {}),
        "dynamic_budget_comparison": candidate_mcts_report.get(
            "dynamic_budget_comparison", candidate_budget.get("dynamic_budget_comparison")
        ),
    }


def build_dynamic_budget_recommendation(
    *,
    passed: bool,
    arena_score_value: float,
    candidate_mcts_score_value: float,
    current_mcts_score_value: float,
    dynamic_budget: dict | None,
    failure_reasons: list[dict],
) -> dict:
    comparison = {}
    if isinstance(dynamic_budget, dict):
        candidate_comparison = dynamic_budget.get("dynamic_budget_comparison")
        if isinstance(candidate_comparison, dict):
            comparison = candidate_comparison

    decision = "tune"
    reason = "promotion safety passed, but dynamic budget evidence is incomplete or mixed"
    if not passed:
        decision = "drop"
        reason = "promotion safety checks failed for the dynamic budget candidate"
    else:
        runtime_target_matched = bool(comparison.get("runtime_target_matched"))
        dynamic_score = comparison.get("dynamic_score")
        fixed_score = comparison.get("fixed_score")
        favorable_comparison = (
            runtime_target_matched
            and dynamic_score is not None
            and fixed_score is not None
            and float(dynamic_score) >= float(fixed_score)
        )
        if favorable_comparison:
            decision = "keep"
            reason = "promotion safety checks passed and dynamic budget evidence stayed favorable under the matched runtime target"

    return {
        "decision": decision,
        "reason": reason,
        "evidence": {
            "promotion_safety_passed": bool(passed),
            "arena_score": arena_score_value,
            "candidate_mcts_score": candidate_mcts_score_value,
            "current_mcts_score": current_mcts_score_value,
            "dynamic_budget": dynamic_budget,
            "failure_reasons": [row.get("code") for row in failure_reasons],
        },
    }


def hard_suite_bucket_breakdown(hard_report: dict | None) -> dict:
    if hard_report is None:
        return {}

    direct_buckets = hard_report.get("hard_suite_buckets")
    if isinstance(direct_buckets, dict):
        return direct_buckets

    return {}


def build_endgame_exact_solve_section(*, status: str, results_source: str, results: list[dict]) -> dict:
    return {
        "status": status,
        "scaffold_only": True,
        "results_source": results_source,
        "thresholds": [8, 10, 12],
        "results": results,
        "planned_evaluations": [],
        "recommendation": {
            "enabled": False,
            "threshold": None,
            "reason": "endgame exact solve threshold data is scaffold metadata only until threshold-specific evaluations run",
        },
    }


def build_endgame_exact_solve_recommendation(results: list[dict]) -> dict:
    if not results:
        return {
            "enabled": False,
            "threshold": None,
            "reason": "endgame exact solve threshold data is scaffold metadata only until threshold-specific evaluations run",
        }

    best_result = max(
        results,
        key=lambda row: (
            float(row.get("candidate_mcts_score", 0.0)) - float(row.get("current_mcts_score", 0.0)),
            float(row.get("candidate_mcts_score", 0.0)),
            -int(row.get("threshold", 0)),
        ),
    )
    best_gain = round(
        float(best_result.get("candidate_mcts_score", 0.0)) - float(best_result.get("current_mcts_score", 0.0)),
        4,
    )
    if best_gain <= 0.0:
        return {
            "enabled": False,
            "threshold": None,
            "reason": "no threshold improved candidate-vs-mcts1200 score over the current baseline",
        }

    return {
        "enabled": True,
        "threshold": int(best_result["threshold"]),
        "reason": f"threshold {int(best_result['threshold'])} delivered the best candidate-vs-mcts1200 gain ({best_gain:+.4f})",
    }


def build_endgame_exact_solve_plans(args: argparse.Namespace, *, report_dir: Path, search_flag_map: dict[str, list[str]]) -> list[dict]:
    plans = []
    for threshold in (8, 10, 12):
        candidate_report_path = report_dir / f"endgame_exact_solve_threshold_{threshold}_candidate_vs_mcts1200.json"
        current_report_path = report_dir / f"endgame_exact_solve_threshold_{threshold}_current_vs_mcts1200.json"
        summary_report_path = report_dir / f"endgame_exact_solve_threshold_{threshold}.json"
        plans.append(
            {
                "threshold": threshold,
                "status": "planned",
                "scaffold_only": True,
                "mode": "planned",
                "report_path": str(summary_report_path),
                "candidate_mcts_report_path": str(candidate_report_path),
                "current_mcts_report_path": str(current_report_path),
                "candidate_mcts_command": [
                    python_executable(),
                    "ml/alphazero_lite/mcts1200_baseline.py",
                    "--challenger-path",
                    str(args.candidate_path),
                    "--games",
                    str(args.mcts_games),
                    *search_flag_map.get("candidate_mcts", []),
                    "--exact-solve-enabled",
                    "--exact-solve-stone-threshold",
                    str(threshold),
                    "--out",
                    str(candidate_report_path),
                ],
                "current_mcts_command": [
                    python_executable(),
                    "ml/alphazero_lite/mcts1200_baseline.py",
                    "--challenger-path",
                    str(args.current_path),
                    "--games",
                    str(args.mcts_games),
                    *search_flag_map.get("current_mcts", []),
                    "--exact-solve-enabled",
                    "--exact-solve-stone-threshold",
                    str(threshold),
                    "--out",
                    str(current_report_path),
                ],
            }
        )
    return plans


def build_decision_report(
    args: argparse.Namespace,
    report: dict,
    *,
    arena_report: dict,
    hard_report: dict | None,
    candidate_mcts_report: dict,
    current_mcts_report: dict,
    regression_report: dict,
    arena_report_path: Path,
    hard_report_path: Path | None,
    candidate_mcts_report_path: Path,
    current_mcts_report_path: Path,
    regression_report_path: Path,
) -> dict:
    planned_evaluations = list(report.get("endgame_exact_solve", {}).get("planned_evaluations", []))
    existing_threshold_results = list(report.get("endgame_exact_solve", {}).get("results", []))
    arena_games_played = int(arena_report.get("games_played", 0))
    arena_losses = int(arena_report.get("losses", 0))
    candidate_mcts_games = int(candidate_mcts_report.get("games", 0))
    current_mcts_games = int(current_mcts_report.get("games", 0))

    raw_arena_score = arena_score(arena_report)
    raw_candidate_mcts_score = mcts_score(candidate_mcts_report)
    raw_current_mcts_score = mcts_score(current_mcts_report)

    computed_arena_score = round(raw_arena_score, 4)
    computed_candidate_mcts_score = round(raw_candidate_mcts_score, 4)
    computed_current_mcts_score = round(raw_current_mcts_score, 4)

    failure_reasons = []
    if arena_games_played < args.min_arena_games:
        failure_reasons.append({"code": "arena_games_below_minimum"})
    if candidate_mcts_games < args.min_mcts_games:
        failure_reasons.append({"code": "candidate_mcts_games_below_minimum"})
    if current_mcts_games < args.min_mcts_games:
        failure_reasons.append({"code": "current_mcts_games_below_minimum"})
    if raw_arena_score < args.min_arena_score:
        failure_reasons.append({"code": "arena_score_below_threshold"})
    if args.require_lossless and arena_losses > args.max_losses:
        failure_reasons.append({"code": "arena_losses_above_threshold"})
    if not args.skip_mcts_relative_check and raw_candidate_mcts_score < raw_current_mcts_score:
        failure_reasons.append({"code": "candidate_mcts_below_current"})
    if not regression_report.get("passed", False):
        failure_reasons.append({"code": "regression_check_failed"})

    notes = arena_report.get("notes", {}) if isinstance(arena_report.get("notes", {}), dict) else {}
    move_time_mean_ms = notes.get("move_time_mean_ms", arena_report.get("move_time_mean_ms"))
    move_time_p95_ms = notes.get("move_time_p95_ms", arena_report.get("move_time_p95_ms"))
    if args.max_arena_move_time_mean_ms is not None:
        if move_time_mean_ms is None:
            failure_reasons.append({"code": "arena_move_time_mean_missing"})
        elif float(move_time_mean_ms) > args.max_arena_move_time_mean_ms:
            failure_reasons.append({"code": "arena_move_time_mean_above_threshold"})
    if args.max_arena_move_time_p95_ms is not None:
        if move_time_p95_ms is None:
            failure_reasons.append({"code": "arena_move_time_p95_missing"})
        elif float(move_time_p95_ms) > args.max_arena_move_time_p95_ms:
            failure_reasons.append({"code": "arena_move_time_p95_above_threshold"})

    computed_hard_score: float | None = None
    if hard_report is not None:
        hard_games_played = int(hard_report.get("games_played", 0))
        raw_hard_score = arena_score(hard_report)
        computed_hard_score = round(raw_hard_score, 4)
        if hard_games_played < args.hard_arena_games:
            failure_reasons.append({"code": "hard_games_below_minimum"})
        if raw_hard_score < args.hard_min_score:
            failure_reasons.append({"code": "candidate_not_stronger_than_hard"})

    report.update(
        {
            "arena_report_path": str(arena_report_path),
            "hard_report_path": str(hard_report_path) if hard_report_path is not None else None,
            "candidate_mcts_report_path": str(candidate_mcts_report_path),
            "current_mcts_report_path": str(current_mcts_report_path),
            "regression_report_path": str(regression_report_path),
            "arena_score": computed_arena_score,
            "hard_score": computed_hard_score,
            "arena_losses": arena_losses,
            "candidate_mcts_score": computed_candidate_mcts_score,
            "current_mcts_score": computed_current_mcts_score,
            "dynamic_budget": dynamic_budget_summary(candidate_mcts_report, current_mcts_report, arena_report),
            "hard_suite_buckets": hard_suite_bucket_breakdown(hard_report),
            "lossless_passed": arena_losses <= args.max_losses,
            "passed": not failure_reasons,
            "failure_reasons": failure_reasons,
            "endgame_exact_solve": build_endgame_exact_solve_section(
                status="executed" if existing_threshold_results else "planned_only",
                results_source="threshold_specific_reports" if existing_threshold_results else "planned_evaluation_metadata_only",
                results=existing_threshold_results,
            ),
        }
    )
    report["dynamic_budget_recommendation"] = build_dynamic_budget_recommendation(
        passed=report["passed"],
        arena_score_value=computed_arena_score,
        candidate_mcts_score_value=computed_candidate_mcts_score,
        current_mcts_score_value=computed_current_mcts_score,
        dynamic_budget=report["dynamic_budget"],
        failure_reasons=failure_reasons,
    )
    report["endgame_exact_solve"]["planned_evaluations"] = planned_evaluations
    report["endgame_exact_solve"]["scaffold_only"] = not bool(existing_threshold_results)
    report["endgame_exact_solve"]["recommendation"] = build_endgame_exact_solve_recommendation(existing_threshold_results)
    return report


def build_stub_decision_report(args: argparse.Namespace, report: dict) -> dict:
    hard_report = load_json(args.stub_hard_report) if args.stub_hard_report is not None else None
    regression_report = (
        load_json(args.stub_regression_report)
        if args.stub_regression_report is not None
        else default_regression_report(args.regression_positions_path)
    )
    regression_report_path = args.stub_regression_report or Path(report["regression_report_path"])
    return build_decision_report(
        args,
        report,
        arena_report=load_json(args.stub_arena_report),
        hard_report=hard_report,
        candidate_mcts_report=load_json(args.stub_candidate_mcts_report),
        current_mcts_report=load_json(args.stub_current_mcts_report),
        regression_report=regression_report,
        arena_report_path=args.stub_arena_report,
        hard_report_path=args.stub_hard_report,
        candidate_mcts_report_path=args.stub_candidate_mcts_report,
        current_mcts_report_path=args.stub_current_mcts_report,
        regression_report_path=regression_report_path,
    )


def run_command(command: list[str]) -> None:
    result = subprocess.run(
        command,
        cwd=repo_root(),
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        details = (result.stderr or result.stdout).strip()
        command_label = Path(command[1]).name if len(command) > 1 else command[0]
        if details:
            raise SystemExit(f"{command_label} failed: {details}")
        raise SystemExit(f"{command_label} failed: {' '.join(command)}")


def run_regression_check(command: list[str], report_path: Path) -> dict:
    if report_path.exists():
        report_path.unlink()
    command_with_output = [*command, "--out", str(report_path)]
    result = subprocess.run(
        command_with_output,
        cwd=repo_root(),
        capture_output=True,
        text=True,
        check=False,
    )

    stdout = result.stdout.strip()
    if result.returncode != 0:
        details = (result.stderr or stdout).strip()
        if details:
            raise SystemExit(f"check_superhuman_regressions failed: {details}")
        raise SystemExit("check_superhuman_regressions failed")

    report_text = report_path.read_text(encoding="utf-8").strip() if report_path.exists() else stdout

    try:
        report = json.loads(report_text)
    except json.JSONDecodeError as exc:
        details = (result.stderr or report_text or stdout).strip()
        if details:
            raise SystemExit(f"check_superhuman_regressions failed: {details}") from exc
        raise SystemExit("check_superhuman_regressions failed") from exc

    if result.returncode not in (0, 1):
        details = (result.stderr or stdout).strip()
        if details:
            raise SystemExit(f"check_superhuman_regressions failed: {details}")
        raise SystemExit("check_superhuman_regressions failed")

    if not isinstance(report, dict) or "passed" not in report:
        raise SystemExit("check_superhuman_regressions failed: missing passed field")

    return report


def build_real_decision_report(args: argparse.Namespace, report: dict) -> dict:
    evaluations = {evaluation["id"]: evaluation for evaluation in report["evaluations"]}
    arena_report_path = Path(evaluations["candidate_vs_current_arena"]["report_path"])
    candidate_mcts_report_path = Path(evaluations["candidate_vs_mcts1200"]["report_path"])
    current_mcts_report_path = Path(evaluations["current_vs_mcts1200"]["report_path"])
    hard_report_path = Path(evaluations["candidate_vs_hard_arena"]["report_path"]) if "candidate_vs_hard_arena" in evaluations else None
    regression_report_path = Path(report["regression_report_path"])
    search_flag_map = load_search_flag_map(args.config_path)

    run_command(
        [
            python_executable(),
            "ml/alphazero_lite/arena.py",
            "--challenger",
            str(args.candidate_path),
            "--current",
            str(args.current_path),
            "--games",
            str(args.arena_games),
            *search_flag_map.get("arena", []),
            "--min-score",
            str(args.min_arena_score),
            "--out",
            str(arena_report_path),
        ]
    )
    if args.hard_path is not None:
        run_command(
            [
                python_executable(),
                "ml/alphazero_lite/arena.py",
                "--challenger",
                str(args.candidate_path),
                "--current",
                str(args.hard_path),
                "--games",
                str(args.hard_arena_games),
                *search_flag_map.get("arena", []),
                "--min-score",
                str(args.hard_min_score),
                "--out",
                str(hard_report_path),
            ]
        )
    run_command(
        [
            python_executable(),
            "ml/alphazero_lite/mcts1200_baseline.py",
            "--challenger-path",
            str(args.candidate_path),
            "--games",
            str(args.mcts_games),
            *search_flag_map.get("candidate_mcts", []),
            "--out",
            str(candidate_mcts_report_path),
        ]
    )
    run_command(
        [
            python_executable(),
            "ml/alphazero_lite/mcts1200_baseline.py",
            "--challenger-path",
            str(args.current_path),
            "--games",
            str(args.mcts_games),
            *search_flag_map.get("current_mcts", []),
            "--out",
            str(current_mcts_report_path),
        ]
    )
    regression_report = run_regression_check(
        [
            "script/ai/check_superhuman_regressions",
            "--artifact",
            str(args.candidate_path),
            "--positions",
            str(args.regression_positions_path),
            *search_flag_map.get("arena", []),
        ],
        regression_report_path,
    )

    threshold_results = []
    for planned_evaluation in report["endgame_exact_solve"]["planned_evaluations"]:
        run_command(planned_evaluation["candidate_mcts_command"])
        run_command(planned_evaluation["current_mcts_command"])
        candidate_threshold_report = load_json(Path(planned_evaluation["candidate_mcts_report_path"]))
        current_threshold_report = load_json(Path(planned_evaluation["current_mcts_report_path"]))
        threshold_summary = {
            "threshold": int(planned_evaluation["threshold"]),
            "mode": "executed",
            "score": round(mcts_score(candidate_threshold_report), 4),
            "candidate_mcts_score": round(mcts_score(candidate_threshold_report), 4),
            "current_mcts_score": round(mcts_score(current_threshold_report), 4),
            "candidate_mcts_report_path": planned_evaluation["candidate_mcts_report_path"],
            "current_mcts_report_path": planned_evaluation["current_mcts_report_path"],
        }
        Path(planned_evaluation["report_path"]).write_text(json.dumps(threshold_summary, indent=2), encoding="utf-8")
        planned_evaluation["status"] = "executed"
        planned_evaluation["mode"] = "executed"
        planned_evaluation["scaffold_only"] = False
        threshold_results.append(threshold_summary)

    report["endgame_exact_solve"]["results"] = threshold_results

    for evaluation in report["evaluations"]:
        evaluation["mode"] = "executed"

    hard_report = load_json(hard_report_path) if hard_report_path is not None else None
    return build_decision_report(
        args,
        report,
        arena_report=load_json(arena_report_path),
        hard_report=hard_report,
        candidate_mcts_report=load_json(candidate_mcts_report_path),
        current_mcts_report=load_json(current_mcts_report_path),
        regression_report=regression_report,
        arena_report_path=arena_report_path,
        hard_report_path=hard_report_path,
        candidate_mcts_report_path=candidate_mcts_report_path,
        current_mcts_report_path=current_mcts_report_path,
        regression_report_path=regression_report_path,
    )



def main() -> int:
    args = parse_args()
    args.out.parent.mkdir(parents=True, exist_ok=True)
    if args.dry_run and args.config_path:
        load_search_flag_map(args.config_path, require_steps=False)

    non_hard_stub_paths = (
        args.stub_arena_report,
        args.stub_candidate_mcts_report,
        args.stub_current_mcts_report,
    )
    if any(path is not None for path in non_hard_stub_paths) and not all(path is not None for path in non_hard_stub_paths):
        raise SystemExit("provide all stub report paths or none")
    if args.stub_hard_report is not None and args.hard_path is None:
        raise SystemExit("--stub-hard-report requires --hard-path")

    candidate_path = str(args.candidate_path)
    current_path = args.current_path
    mode = "dry_run" if args.dry_run else "planned"

    evaluations = [
        build_evaluation(
            evaluation_id="candidate_vs_current_arena",
            subject=candidate_path,
            opponent=current_path,
            games=args.arena_games,
            report_dir=args.out.parent,
            mode=mode,
        ),
    ]
    if args.hard_path is not None:
        evaluations.append(
            build_evaluation(
                evaluation_id="candidate_vs_hard_arena",
                subject=candidate_path,
                opponent=args.hard_path,
                games=args.hard_arena_games,
                report_dir=args.out.parent,
                mode=mode,
            )
        )
    evaluations.extend(
        [
            build_evaluation(
                evaluation_id="candidate_vs_mcts1200",
                subject=candidate_path,
                opponent="mcts1200",
                games=args.mcts_games,
                report_dir=args.out.parent,
                mode=mode,
            ),
            build_evaluation(
                evaluation_id="current_vs_mcts1200",
                subject=current_path,
                opponent="mcts1200",
                games=args.mcts_games,
                report_dir=args.out.parent,
                mode=mode,
            ),
        ]
    )

    report = {
        "schema": "azlite_local_promotion_gate_v1",
        "candidate_path": candidate_path,
        "config_path": args.config_path,
        "current_path": current_path,
        "hard_path": args.hard_path,
        "regression_positions_path": args.regression_positions_path,
        "report_path": str(args.out),
        "regression_report_path": str(args.stub_regression_report) if args.stub_regression_report is not None else str(args.out.parent / "candidate_regression_suite.json"),
        "arena_games": args.arena_games,
        "mcts_games": args.mcts_games,
        "hard_arena_games": args.hard_arena_games,
        "min_arena_score": args.min_arena_score,
        "hard_min_score": args.hard_min_score,
        "min_arena_games": args.min_arena_games,
        "min_mcts_games": args.min_mcts_games,
        "require_lossless": args.require_lossless,
        "max_losses": args.max_losses,
        "max_arena_move_time_mean_ms": args.max_arena_move_time_mean_ms,
        "max_arena_move_time_p95_ms": args.max_arena_move_time_p95_ms,
        "skip_mcts_relative_check": args.skip_mcts_relative_check,
        "dry_run": args.dry_run,
        "evaluations": evaluations,
        "endgame_exact_solve": build_endgame_exact_solve_section(
            status="planned_only",
            results_source="evaluation_plan",
            results=[],
        ),
    }

    search_flag_map = load_search_flag_map(args.config_path, require_steps=not args.dry_run) if args.config_path else {}
    report["endgame_exact_solve"]["planned_evaluations"] = build_endgame_exact_solve_plans(
        args,
        report_dir=args.out.parent,
        search_flag_map=search_flag_map,
    )

    stub_reports_provided = all(path is not None for path in non_hard_stub_paths)

    if stub_reports_provided:
        report = build_stub_decision_report(args, report)
    elif not args.dry_run:
        report = build_real_decision_report(args, report)

    args.out.write_text(json.dumps(report, indent=2), encoding="utf-8")
    print(json.dumps({"report_path": str(args.out), "dry_run": args.dry_run}))
    if not args.dry_run and not report.get("passed", True):
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
