def repo_root() -> Path:
    return Path(__file__).resolve().parents[2]


def worktree_workspace_root(root: Path) -> Path | None:
    if root.parent.name != ".worktrees":
        return None
    return root.parent.parent


def python_executable() -> str:
    root = repo_root()
    candidates = [root / ".venv/bin/python"]
    workspace_root = worktree_workspace_root(root)
    if workspace_root is not None:
        candidates.append(workspace_root / ".venv/bin/python")
    for ancestor in root.parents:
        candidates.append(ancestor / ".venv/bin/python")

    seen: set[Path] = set()
    for candidate in candidates:
        if candidate in seen:
            continue
        seen.add(candidate)
        if candidate.is_file() and os.access(candidate, os.X_OK):
            return str(candidate)
    return sys.executable


def arena_score(report: dict) -> float:
    games_played = int(report.get("games_played", 0))
    if games_played <= 0:
        return 0.0
    wins = int(report.get("wins", 0))
    draws = int(report.get("draws", 0))
    return (wins + (0.5 * draws)) / games_played


def mcts_score(report: dict) -> float:
    games = int(report.get("games", 0))
    if games <= 0:
        return 0.0
    az_wins = int(report.get("az_wins", 0))
    draws = int(report.get("draws", 0))
    return (az_wins + (0.5 * draws)) / games


def normalized_failure_reasons(report: dict) -> list[dict]:
    failure_reasons = report.get("failure_reasons")
    if not isinstance(failure_reasons, list):
        return []

    normalized = []
    for reason in failure_reasons:
        if not isinstance(reason, dict):
            continue
        code = reason.get("code")
        if not isinstance(code, str) or not code:
            continue
        normalized.append(reason)
    return normalized


def arena_prefilter_failure_reasons(
    args: argparse.Namespace, arena_report: dict
) -> list[dict]:
    failure_reasons = computed_arena_prefilter_threshold_failures(args, arena_report)
    return failure_reasons or [{"code": "arena_prefilter_failed"}]


def computed_arena_prefilter_threshold_failures(
    args: argparse.Namespace, arena_report: dict
) -> list[dict]:
    existing_reasons = normalized_failure_reasons(arena_report)
    if existing_reasons:
        return existing_reasons

    failure_reasons = []
    arena_games_played = int(arena_report.get("games_played", 0))
    arena_losses = int(arena_report.get("losses", 0))
    raw_arena_score = arena_score(arena_report)

    if arena_games_played < args.min_arena_games:
        failure_reasons.append({"code": "arena_games_below_minimum"})
    if raw_arena_score < args.min_arena_score:
        failure_reasons.append({"code": "arena_score_below_threshold"})
    if args.require_lossless and arena_losses > args.max_losses:
        failure_reasons.append({"code": "arena_losses_above_threshold"})

    notes = (
        arena_report.get("notes", {})
        if isinstance(arena_report.get("notes", {}), dict)
        else {}
    )
    move_time_mean_ms = notes.get(
        "move_time_mean_ms", arena_report.get("move_time_mean_ms")
    )
    move_time_p95_ms = notes.get(
        "move_time_p95_ms", arena_report.get("move_time_p95_ms")
    )
    if args.max_arena_move_time_mean_ms is not None:
        if move_time_mean_ms is None:
            failure_reasons.append({"code": "arena_move_time_mean_missing"})
        elif float(move_time_mean_ms) > args.max_arena_move_time_mean_ms:
            failure_reasons.append({"code": "arena_move_time_mean_above_threshold"})
    if args.max_arena_move_time_p95_ms is not None:
        if move_time_p95_ms is None:
            failure_reasons.append({"code": "arena_move_time_p95_missing"})
        elif float(move_time_p95_ms) > args.max_arena_move_time_p95_ms:
            failure_reasons.append({"code": "arena_move_time_p95_above_threshold"})

    return failure_reasons


def dynamic_budget_summary(
    candidate_mcts_report: dict, current_mcts_report: dict, arena_report: dict
) -> dict | None:
    candidate_budget = candidate_mcts_report.get("budget_summary", {})
    current_budget = current_mcts_report.get("budget_summary", {})
    arena_budget = arena_report.get("budget_summary", {})
    opening_cache_summary = arena_report.get("opening_cache_summary")
    if not any((candidate_budget, current_budget, arena_budget, opening_cache_summary)):
        return None

    return {
        "candidate_mean_final_simulations": candidate_budget.get(
            "mean_final_simulations"
        ),
        "candidate_mean_root_latency_ms": candidate_budget.get("mean_root_latency_ms"),
        "current_mean_final_simulations": current_budget.get("mean_final_simulations"),
        "current_mean_root_latency_ms": current_budget.get("mean_root_latency_ms"),
        "arena_trigger_counts": arena_budget.get("trigger_counts", {}),
        "dynamic_budget_comparison": candidate_mcts_report.get(
            "dynamic_budget_comparison",
            candidate_budget.get("dynamic_budget_comparison"),
        ),
        "opening_cache_summary": opening_cache_summary,
    }


def build_dynamic_budget_recommendation(
    *,
    passed: bool,
    arena_score_value: float,
    candidate_mcts_score_value: float,
    current_mcts_score_value: float,
    dynamic_budget: dict | None,
    failure_reasons: list[dict],
) -> dict:
    comparison = {}
    if isinstance(dynamic_budget, dict):
        candidate_comparison = dynamic_budget.get("dynamic_budget_comparison")
        if isinstance(candidate_comparison, dict):
            comparison = candidate_comparison

    decision = "tune"
    reason = (
        "promotion safety passed, but dynamic budget evidence is incomplete or mixed"
    )
    if not passed:
        decision = "drop"
        reason = "promotion safety checks failed for the dynamic budget candidate"
    else:
        runtime_target_matched = bool(comparison.get("runtime_target_matched"))
        dynamic_score = comparison.get("dynamic_score")
        fixed_score = comparison.get("fixed_score")
        favorable_comparison = (
            runtime_target_matched
            and dynamic_score is not None
            and fixed_score is not None
            and float(dynamic_score) >= float(fixed_score)
        )
        if favorable_comparison:
            decision = "keep"
            reason = "promotion safety checks passed and dynamic budget evidence stayed favorable under the matched runtime target"

    return {
        "decision": decision,
        "reason": reason,
        "evidence": {
            "promotion_safety_passed": bool(passed),
            "arena_score": arena_score_value,
            "candidate_mcts_score": candidate_mcts_score_value,
            "current_mcts_score": current_mcts_score_value,
            "dynamic_budget": dynamic_budget,
            "failure_reasons": [row.get("code") for row in failure_reasons],
        },
    }


def build_opening_cache_recommendation(*, opening_cache_summary: dict | None) -> dict:
    if not isinstance(opening_cache_summary, dict):
        return {
            "decision": "tune",
            "reason": "opening memoization evidence is unavailable, so promotion odds impact is still unclear",
            "evidence": {"opening_cache_summary": None},
        }

    runtime_hit_rate = opening_cache_summary.get("runtime_hit_rate")
    training_hit_rate = opening_cache_summary.get("training_hit_rate")
    quality_delta = opening_cache_summary.get("opening_bucket_quality_delta")
    latency_delta_ms = opening_cache_summary.get("latency_delta_ms")
    evidence_available = all(
        value is not None
        for value in (
            runtime_hit_rate,
            training_hit_rate,
            quality_delta,
            latency_delta_ms,
        )
    )

    if not evidence_available:
        return {
            "decision": "tune",
            "reason": "opening memoization runtime evidence is unavailable, so promotion odds impact is still unclear",
            "evidence": {
                "opening_cache_summary": {
                    "runtime_hit_rate": runtime_hit_rate,
                    "training_hit_rate": training_hit_rate,
                    "opening_bucket_quality_delta": quality_delta,
                    "latency_delta_ms": latency_delta_ms,
                }
            },
        }

    favorable = (
        float(runtime_hit_rate) > 0.0
        and float(training_hit_rate) > 0.0
        and float(quality_delta) >= 0.0
        and float(latency_delta_ms) <= 0.0
    )

    if favorable:
        decision = "keep"
        reason = "opening memoization improved promotion odds enough to keep based on favorable hit-rate, quality, and latency evidence"
    else:
        decision = "drop"
        reason = "opening memoization did not improve promotion odds enough to keep because the hit-rate, quality, or latency evidence was unfavorable"

    return {
        "decision": decision,
        "reason": reason,
        "evidence": {
            "opening_cache_summary": {
                "runtime_hit_rate": runtime_hit_rate,
                "training_hit_rate": training_hit_rate,
                "opening_bucket_quality_delta": quality_delta,
                "latency_delta_ms": latency_delta_ms,
            }
        },
    }


