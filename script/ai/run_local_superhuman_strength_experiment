#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
PYTHON_BIN="$ROOT_DIR/.venv/bin/python"
if [[ ! -x "$PYTHON_BIN" ]]; then
  PYTHON_BIN="python3"
fi
PYTHON_BIN="${AZLITE_EXPERIMENT_PYTHON:-$PYTHON_BIN}"

RUN_ID=""
GAMES_JSON="$ROOT_DIR/ml/alphazero_lite/fixtures/superhuman_strength_games_2026_04_06.json"
OUTPUT_ROOT="$ROOT_DIR/tmp/local_superhuman_strength"
SELF_PLAY_GAMES="400"
BOOTSTRAP_GAMES="320"
ARENA_GAMES="120"
MCTS_GAMES="40"
DRY_RUN=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --run-id)
      RUN_ID="$2"
      shift 2
      ;;
    --games-json)
      GAMES_JSON="$2"
      shift 2
      ;;
    --output-root)
      OUTPUT_ROOT="$2"
      shift 2
      ;;
    --self-play-games)
      SELF_PLAY_GAMES="$2"
      shift 2
      ;;
    --bootstrap-games)
      BOOTSTRAP_GAMES="$2"
      shift 2
      ;;
    --arena-games)
      ARENA_GAMES="$2"
      shift 2
      ;;
    --mcts-games)
      MCTS_GAMES="$2"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

if [[ -z "$RUN_ID" ]]; then
  echo "Usage: script/ai/run_local_superhuman_strength_experiment --run-id VALUE [--games-json PATH] [--output-root PATH] [--self-play-games N] [--bootstrap-games N] [--arena-games N] [--mcts-games N] [--dry-run]" >&2
  exit 1
fi

BASE_DIR="$OUTPUT_ROOT/$RUN_ID"
VERSIONS_DIR="$BASE_DIR/versions"
CURATED_DATASET_PATH="$BASE_DIR/curated_superhuman_strength.jsonl"
CURRENT_INIT_CHECKPOINT_PATH="$BASE_DIR/current_init_checkpoint.npz"
STAGE1_CONFIG_PATH="$BASE_DIR/stage1_config.json"
STAGE2_CONFIG_PATH="$BASE_DIR/stage2_config.json"
LANE_A_REPORT_PATH="$BASE_DIR/lane_a_promotion_report.json"
LANE_B_REPORT_PATH="$BASE_DIR/lane_b_promotion_report.json"
SEARCH_CONFIG_PATH="$ROOT_DIR/ml/alphazero_lite/configs/aggressive_v3_superhuman_search_control.json"

mkdir -p "$BASE_DIR"

"$PYTHON_BIN" "$ROOT_DIR/ml/alphazero_lite/build_superhuman_strength_dataset.py" --games-json "$GAMES_JSON" --out "$CURATED_DATASET_PATH" >/dev/null

"$PYTHON_BIN" - "$ROOT_DIR/model-artifact/current/weights.json" "$CURRENT_INIT_CHECKPOINT_PATH" <<'PY'
import json
import sys
from pathlib import Path

import numpy as np

weights_path = Path(sys.argv[1])
checkpoint_path = Path(sys.argv[2])
weights = json.loads(weights_path.read_text(encoding="utf-8"))
checkpoint_path.parent.mkdir(parents=True, exist_ok=True)
np.savez(checkpoint_path, **{key: np.array(value, dtype=np.float32) for key, value in weights.items()})
PY

"$PYTHON_BIN" - "$ROOT_DIR" "$RUN_ID" "$VERSIONS_DIR" "$CURATED_DATASET_PATH" "$CURRENT_INIT_CHECKPOINT_PATH" "$STAGE1_CONFIG_PATH" "$STAGE2_CONFIG_PATH" "$SELF_PLAY_GAMES" "$BOOTSTRAP_GAMES" "$PYTHON_BIN" <<'PY'
import json
import sys
from pathlib import Path

root_dir = Path(sys.argv[1])
run_id = sys.argv[2]
versions_dir = Path(sys.argv[3])
curated_dataset_path = sys.argv[4]
current_init_checkpoint_path = Path(sys.argv[5])
stage1_config_path = Path(sys.argv[6])
stage2_config_path = Path(sys.argv[7])
self_play_games = sys.argv[8]
bootstrap_games = sys.argv[9]
python_bin = sys.argv[10]

phase1 = json.loads((root_dir / "ml/alphazero_lite/configs/aggressive_v3_superhuman_phase1.json").read_text(encoding="utf-8"))
phase2 = json.loads((root_dir / "ml/alphazero_lite/configs/aggressive_v3_superhuman_phase2.json").read_text(encoding="utf-8"))

stage1_run_id = f"{run_id}-balanced-stage1"
stage2_run_id = f"{run_id}-balanced-stage2"
stage1_iter_dir = versions_dir / f"{stage1_run_id}-iter1"
stage1_checkpoint = stage1_iter_dir / "checkpoint.npz"

def set_flag(command, flag, value):
    if flag in command:
        command[command.index(flag) + 1] = value
    else:
        command.extend([flag, value])

def set_python_bin(command, python_bin):
    if command and command[0] == ".venv/bin/python":
        command[0] = python_bin

def replace_train_command(command, *, data_files, replay_weights, init_checkpoint=None, epochs=None, lr=None, hidden_sizes="96,3"):
    command = list(command)
    set_flag(command, "--data-files", data_files)
    set_flag(command, "--replay-weights", replay_weights)
    set_flag(command, "--hidden-sizes", hidden_sizes)
    set_flag(command, "--model-type", "residual_v3")
    set_flag(command, "--input-encoding", "kalah_v3")
    set_flag(command, "--policy-target-mode", "sharpened")
    set_flag(command, "--value-target-mode", "sharpened")
    if epochs is not None:
        set_flag(command, "--epochs", str(epochs))
    if lr is not None:
        set_flag(command, "--lr", str(lr))
    if init_checkpoint is not None:
        set_flag(command, "--init-checkpoint", str(init_checkpoint))
    return command

stage1 = dict(phase1)
stage1["run_id"] = stage1_run_id
stage1["iterations"] = 1
stage1["replay_window"] = 1
stage1["versions_dir"] = str(versions_dir)
stage1["current_path"] = "model-artifact/current"
stage1_steps = []
for step in stage1["steps"]:
    step = dict(step)
    step["command"] = list(step["command"])
    set_python_bin(step["command"], python_bin)
    if step["name"] == "self_play":
        set_flag(step["command"], "--games", self_play_games)
        set_flag(step["command"], "--simulations", "256")
    elif step["name"] == "mcts_bootstrap_dataset":
        set_flag(step["command"], "--games", bootstrap_games)
        set_flag(step["command"], "--simulations", "2400")
    elif step["name"] == "train":
        step["command"] = replace_train_command(
            step["command"],
            data_files=f"{{replay_data}},{{iter_dir}}/mcts_bootstrap.jsonl,{curated_dataset_path}",
            replay_weights="{replay_weights},4,1",
            init_checkpoint=current_init_checkpoint_path,
            epochs=6,
            lr="3e-4",
        )
    stage1_steps.append(step)
stage1["steps"] = stage1_steps

stage2 = dict(phase2)
stage2["run_id"] = stage2_run_id
stage2["iterations"] = 1
stage2.pop("start_iteration", None)
stage2["replay_window"] = 1
stage2["versions_dir"] = str(versions_dir)
stage2["current_path"] = "model-artifact/current"
stage2_steps = []
for step in stage2["steps"]:
    step = dict(step)
    step["command"] = list(step["command"])
    set_python_bin(step["command"], python_bin)
    if step["name"] == "self_play":
        set_flag(step["command"], "--games", self_play_games)
        set_flag(step["command"], "--simulations", "320")
        set_flag(step["command"], "--checkpoint", str(stage1_checkpoint))
    elif step["name"] == "mcts_bootstrap_dataset":
        step["command"] = ["bash", "-lc", "printf '' > '{iter_dir}/mcts_bootstrap.jsonl'"]
    elif step["name"] == "train":
        step["command"] = replace_train_command(
            step["command"],
            data_files=f"{{replay_data}},{curated_dataset_path}",
            replay_weights="{replay_weights},1",
            init_checkpoint=stage1_checkpoint,
            epochs=4,
            lr="1e-4",
        )
    stage2_steps.append(step)
stage2["steps"] = stage2_steps

stage1_config_path.parent.mkdir(parents=True, exist_ok=True)
stage1_config_path.write_text(json.dumps(stage1, indent=2), encoding="utf-8")
stage2_config_path.write_text(json.dumps(stage2, indent=2), encoding="utf-8")
PY

LANE_A_GATE_COMMAND=(
  "$ROOT_DIR/script/ai/local_promotion_gate"
  --candidate-path "$ROOT_DIR/model-artifact/current"
  --current-path "$ROOT_DIR/model-artifact/current"
  --hard-path "$ROOT_DIR/model-artifact/current"
  --config-path "$SEARCH_CONFIG_PATH"
  --arena-games "$ARENA_GAMES"
  --min-arena-score "0.0"
  --hard-min-score "0.0"
  --mcts-games "$MCTS_GAMES"
  --skip-mcts-relative-check
  --out "$LANE_A_REPORT_PATH"
)

LANE_B_STAGE1_COMMAND=(
  "$PYTHON_BIN"
  "$ROOT_DIR/ml/alphazero_lite/pipeline.py"
  --config "$STAGE1_CONFIG_PATH"
  --iterations 1
)

LANE_B_STAGE2_COMMAND=(
  "$PYTHON_BIN"
  "$ROOT_DIR/ml/alphazero_lite/pipeline.py"
  --config "$STAGE2_CONFIG_PATH"
  --iterations 1
)

LANE_B_GATE_COMMAND=(
  "$ROOT_DIR/script/ai/local_promotion_gate"
  --candidate-path "$VERSIONS_DIR/${RUN_ID}-balanced-stage2-iter1"
  --current-path "$ROOT_DIR/model-artifact/current"
  --hard-path "$ROOT_DIR/model-artifact/current"
  --config-path "$SEARCH_CONFIG_PATH"
  --arena-games "$ARENA_GAMES"
  --mcts-games "$MCTS_GAMES"
  --out "$LANE_B_REPORT_PATH"
)

if [[ "$DRY_RUN" == "0" ]]; then
  "${LANE_A_GATE_COMMAND[@]}" >&2
  "${LANE_B_STAGE1_COMMAND[@]}" >&2
  "${LANE_B_STAGE2_COMMAND[@]}" >&2
  "${LANE_B_GATE_COMMAND[@]}" >&2
fi

LANE_A_GATE_COMMAND_JSON="$(printf '%s\n' "${LANE_A_GATE_COMMAND[@]}")"
LANE_B_STAGE1_COMMAND_JSON="$(printf '%s\n' "${LANE_B_STAGE1_COMMAND[@]}")"
LANE_B_STAGE2_COMMAND_JSON="$(printf '%s\n' "${LANE_B_STAGE2_COMMAND[@]}")"
LANE_B_GATE_COMMAND_JSON="$(printf '%s\n' "${LANE_B_GATE_COMMAND[@]}")"

LANE_A_GATE_COMMAND_JSON="$LANE_A_GATE_COMMAND_JSON" \
LANE_B_STAGE1_COMMAND_JSON="$LANE_B_STAGE1_COMMAND_JSON" \
LANE_B_STAGE2_COMMAND_JSON="$LANE_B_STAGE2_COMMAND_JSON" \
LANE_B_GATE_COMMAND_JSON="$LANE_B_GATE_COMMAND_JSON" \
"$PYTHON_BIN" - "$RUN_ID" "$CURATED_DATASET_PATH" "$STAGE1_CONFIG_PATH" "$STAGE2_CONFIG_PATH" "$SEARCH_CONFIG_PATH" "$LANE_A_REPORT_PATH" "$LANE_B_REPORT_PATH" <<'PY'
import json
import os
import sys

def command_from_env(key):
    return [part for part in os.environ[key].splitlines() if part]

report = {
    "run_id": sys.argv[1],
    "curated_dataset_path": sys.argv[2],
    "stage1_config_path": sys.argv[3],
    "stage2_config_path": sys.argv[4],
    "search_config_path": sys.argv[5],
    "lane_a_report_path": sys.argv[6],
    "lane_b_report_path": sys.argv[7],
    "lane_a_gate_command": command_from_env("LANE_A_GATE_COMMAND_JSON"),
    "lane_b_stage1_command": command_from_env("LANE_B_STAGE1_COMMAND_JSON"),
    "lane_b_stage2_command": command_from_env("LANE_B_STAGE2_COMMAND_JSON"),
    "lane_b_gate_command": command_from_env("LANE_B_GATE_COMMAND_JSON"),
}
print(json.dumps(report))
PY
