{
  "run_id": "exp-v3-temp-sharp-late",
  "seed": 42,
  "iterations": 1,
  "replay_window": 3,
  "versions_dir": "/tmp/azlite_exp_v3_temp_sharp_late_versions",
  "current_path": "storage/ai/alphazero_lite/current",
  "steps": [
    {
      "name": "self_play",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/self_play.py",
        "--out",
        "{iter_dir}/self_play.jsonl",
        "--games",
        "1600",
        "--workers",
        "6",
        "--seed",
        "42",
        "--seed-sweep",
        "41,42,43",
        "--simulations",
        "192",
        "--temperature-threshold",
        "10",
        "--temperature",
        "1.0",
        "--temperature-late",
        "0.05",
        "--dirichlet-alpha",
        "0.3",
        "--dirichlet-epsilon",
        "0.3",
        "--schedule-progress-mode",
        "linear",
        "--iteration",
        "{iteration}",
        "--total-iterations",
        "2",
        "--tree-reuse-enabled",
        "--input-encoding",
        "kalah_v3",
        "--policy-target-mode",
        "sharpened",
        "--value-target-mode",
        "sharpened"
      ]
    },
    {
      "name": "perspective_audit",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/perspective_audit.py",
        "--data",
        "{iter_dir}/self_play.jsonl",
        "--out",
        "{iter_dir}/perspective_audit.json"
      ]
    },
    {
      "name": "mcts_bootstrap_dataset",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/generate_bootstrap_dataset.py",
        "--out",
        "{iter_dir}/mcts_bootstrap.jsonl",
        "--games",
        "600",
        "--simulations",
        "2400",
        "--seed",
        "42",
        "--max-positions-per-game",
        "16",
        "--workers",
        "5",
        "--tree-reuse-enabled",
        "--input-encoding",
        "kalah_v3",
        "--policy-target-mode",
        "sharpened",
        "--value-target-mode",
        "sharpened"
      ]
    },
    {
      "name": "train",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/train.py",
        "--data-files",
        "{replay_data},{iter_dir}/mcts_bootstrap.jsonl",
        "--replay-weights",
        "{replay_weights},4",
        "--out",
        "{iter_dir}/checkpoint.npz",
        "--epochs",
        "10",
        "--batch-size",
        "512",
        "--device",
        "auto",
        "--hidden-sizes",
        "96,3",
        "--model-type",
        "residual_v3",
        "--input-encoding",
        "kalah_v3",
        "--value-loss",
        "huber",
        "--huber-delta",
        "1.0",
        "--value-loss-weight",
        "0.3",
        "--val-split",
        "0.1",
        "--grad-clip",
        "1.0",
        "--save-top-k",
        "3",
        "--policy-target-mode",
        "sharpened",
        "--value-target-mode",
        "sharpened"
      ]
    },
    {
      "name": "export_artifact",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/export_artifact.py",
        "--checkpoint",
        "{iter_dir}/checkpoint.npz",
        "--out-dir",
        "{iter_dir}",
        "--version",
        "{run_id}-iter{iteration}",
        "--model-type",
        "residual_v3",
        "--rules-version",
        "kalah_v1",
        "--input-encoding",
        "kalah_v3"
      ]
    }
  ]
}
