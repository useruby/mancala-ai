{
  "run_id": "aggressive-v3-mcts-az-hybrid",
  "seed": 168,
  "iterations": 1,
  "replay_window": 3,
  "versions_dir": "/tmp/azlite_v3_mcts_az_hybrid_versions",
  "current_path": "storage/ai/alphazero_lite/current",
  "steps": [
    {
      "name": "self_play",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/self_play.py",
        "--out",
        "{iter_dir}/self_play.jsonl",
        "--games",
        "600",
        "--workers",
        "6",
        "--seed",
        "168",
        "--seed-sweep",
        "161,162,163",
        "--simulations",
        "1200",
        "--player-mode",
        "classic_mcts",
        "--temperature-threshold",
        "12",
        "--temperature",
        "1.1",
        "--temperature-late",
        "0.15",
        "--schedule-progress-mode",
        "linear",
        "--iteration",
        "{iteration}",
        "--total-iterations",
        "1",
        "--input-encoding",
        "kalah_v3",
        "--policy-target-mode",
        "sharpened",
        "--value-target-mode",
        "sharpened"
      ]
    },
    {
      "name": "perspective_audit",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/perspective_audit.py",
        "--data",
        "{iter_dir}/self_play.jsonl",
        "--out",
        "{iter_dir}/perspective_audit.json"
      ]
    },
    {
      "name": "train",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/train.py",
        "--data",
        "{iter_dir}/self_play.jsonl",
        "--data-files",
        "{replay_data}",
        "--replay-weights",
        "{replay_weights}",
        "--out",
        "{iter_dir}/checkpoint.npz",
        "--epochs",
        "10",
        "--batch-size",
        "512",
        "--device",
        "auto",
        "--hidden-sizes",
        "96,3",
        "--model-type",
        "residual_v3",
        "--input-encoding",
        "kalah_v3",
        "--value-loss",
        "huber",
        "--huber-delta",
        "1.0",
        "--value-loss-weight",
        "0.3",
        "--val-split",
        "0.1",
        "--grad-clip",
        "1.0",
        "--save-top-k",
        "3",
        "--policy-target-mode",
        "sharpened",
        "--value-target-mode",
        "sharpened"
      ]
    },
    {
      "name": "export_artifact",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/export_artifact.py",
        "--checkpoint",
        "{iter_dir}/checkpoint.npz",
        "--out-dir",
        "{iter_dir}",
        "--version",
        "{run_id}-iter{iteration}",
        "--model-type",
        "residual_v3",
        "--rules-version",
        "kalah_v1",
        "--input-encoding",
        "kalah_v3"
      ]
    }
  ]
}
