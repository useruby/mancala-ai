{
  "run_id": "human-mix-v1",
  "seed": 42,
  "iterations": 1,
  "start_iteration": 1,
  "replay_window": 1,
  "versions_dir": "/tmp/azlite_human_mix_versions",
  "current_path": "storage/ai/alphazero_lite/current",
  "steps": [
    {
      "name": "train",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/train.py",
        "--data-files",
        "tmp/local_superhuman_results/aggressive-v3-clone-extend-iter2/aggressive-v3-clone-extend-iter2/self_play.jsonl,ml/alphazero_lite/human_games_combined.jsonl",
        "--replay-weights",
        "1,4",
        "--init-checkpoint",
        "storage/ai/alphazero_lite/current/model.npz",
        "--out",
        "{iter_dir}/checkpoint.npz",
        "--epochs",
        "10",
        "--batch-size",
        "512",
        "--lr",
        "1e-3",
        "--device",
        "auto",
        "--hidden-sizes",
        "96,3",
        "--model-type",
        "residual_v3",
        "--input-encoding",
        "kalah_v3",
        "--value-loss",
        "huber",
        "--huber-delta",
        "1.0",
        "--value-loss-weight",
        "0.3",
        "--val-split",
        "0.1",
        "--grad-clip",
        "1.0",
        "--save-top-k",
        "3",
        "--policy-target-mode",
        "default",
        "--value-target-mode",
        "default"
      ]
    },
    {
      "name": "export_artifact",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/export_artifact.py",
        "--checkpoint",
        "{iter_dir}/checkpoint.npz",
        "--out-dir",
        "{iter_dir}",
        "--version",
        "{run_id}-iter{iteration}",
        "--model-type",
        "residual_v3",
        "--rules-version",
        "kalah_v1",
        "--input-encoding",
        "kalah_v3"
      ]
    },
    {
      "name": "arena_prefilter_report",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/arena.py",
        "--challenger",
        "{iter_dir}",
        "--current",
        "storage/ai/alphazero_lite/current",
        "--games",
        "30",
        "--challenger-simulations",
        "640",
        "--current-simulations",
        "256",
        "--workers",
        "6",
        "--out",
        "{iter_dir}/arena_prefilter_report.json",
        "--min-score",
        "0.55"
      ]
    },
    {
      "name": "arena_prefilter_validate",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/validate_arena_report.py",
        "--report",
        "{iter_dir}/arena_prefilter_report.json",
        "--min-score",
        "0.55",
        "--require-pass"
      ]
    },
    {
      "name": "arena_confirm_report",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/arena.py",
        "--challenger",
        "{iter_dir}",
        "--current",
        "storage/ai/alphazero_lite/current",
        "--games",
        "120",
        "--challenger-simulations",
        "640",
        "--current-simulations",
        "256",
        "--workers",
        "6",
        "--out",
        "{iter_dir}/arena_report.json",
        "--min-score",
        "0.55"
      ]
    },
    {
      "name": "mcts1200_baseline_report",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/mcts1200_baseline.py",
        "--challenger-path",
        "{iter_dir}",
        "--games",
        "30",
        "--seed",
        "42",
        "--az-base-simulations",
        "640",
        "--mcts-simulations",
        "1200",
        "--workers",
        "6",
        "--out",
        "{iter_dir}/mcts1200_report.json"
      ]
    },
    {
      "name": "current_mcts1200_baseline_report",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/mcts1200_baseline.py",
        "--challenger-path",
        "storage/ai/alphazero_lite/current",
        "--games",
        "30",
        "--seed",
        "42",
        "--az-base-simulations",
        "640",
        "--mcts-simulations",
        "1200",
        "--workers",
        "6",
        "--out",
        "{iter_dir}/current_mcts1200_report.json"
      ]
    },
    {
      "name": "benchmark_contract",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/benchmark.py",
        "--mode",
        "promotion",
        "--games",
        "60",
        "--seed",
        "42",
        "--challenger-path",
        "{iter_dir}",
        "--current-path",
        "storage/ai/alphazero_lite/current",
        "--arena-report",
        "{iter_dir}/arena_report.json",
        "--min-score",
        "0.55",
        "--mcts-report",
        "{iter_dir}/mcts1200_report.json",
        "--current-baseline-mcts-report",
        "{iter_dir}/current_mcts1200_report.json",
        "--out",
        "{iter_dir}/benchmark_report.json"
      ]
    },
    {
      "name": "arena_validate",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/validate_arena_report.py",
        "--report",
        "{iter_dir}/arena_report.json",
        "--min-score",
        "0.55"
      ]
    }
  ]
}
