{
  "run_id": "aggressive-v3-tactical-encoding-local",
  "seed": 42,
  "iterations": 1,
  "replay_window": 3,
  "versions_dir": "/tmp/azlite_v3_tactical_encoding_local_versions",
  "current_path": "storage/ai/alphazero_lite/current",
  "steps": [
    {
      "name": "self_play",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/self_play.py",
        "--out",
        "{iter_dir}/self_play.jsonl",
        "--games",
        "1600",
        "--workers",
        "6",
        "--seed",
        "42",
        "--seed-sweep",
        "41,42,43",
        "--simulations",
        "192",
        "--temperature-threshold",
        "12",
        "--temperature",
        "1.1",
        "--temperature-late",
        "0.15",
        "--dirichlet-alpha",
        "0.3",
        "--dirichlet-epsilon",
        "0.3",
        "--schedule-progress-mode",
        "linear",
        "--iteration",
        "{iteration}",
        "--total-iterations",
        "1",
        "--tree-reuse-enabled",
        "--checkpoint",
        "{parent_checkpoint}",
        "--input-encoding",
        "kalah_v3",
        "--evaluator-cache-size",
        "50000"
      ]
    },
    {
      "name": "perspective_audit",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/perspective_audit.py",
        "--data",
        "{iter_dir}/self_play.jsonl",
        "--out",
        "{iter_dir}/perspective_audit.json"
      ]
    },
    {
      "name": "mcts_bootstrap_dataset",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/generate_bootstrap_dataset.py",
        "--out",
        "{iter_dir}/mcts_bootstrap.jsonl",
        "--games",
        "600",
        "--simulations",
        "1200",
        "--seed",
        "42",
        "--max-positions-per-game",
        "16",
        "--workers",
        "5",
        "--tree-reuse-enabled",
        "--input-encoding",
        "kalah_v3"
      ]
    },
    {
      "name": "train",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/train.py",
        "--data",
        "{iter_dir}/self_play.jsonl",
        "--data-files",
        "{replay_data},{iter_dir}/mcts_bootstrap.jsonl",
        "--replay-weights",
        "{replay_weights},4",
        "--out",
        "{iter_dir}/checkpoint.npz",
        "--epochs",
        "10",
        "--batch-size",
        "512",
        "--device",
        "auto",
        "--hidden-sizes",
        "64,2",
        "--model-type",
        "residual_v2",
        "--input-encoding",
        "kalah_v3",
        "--value-loss",
        "huber",
        "--huber-delta",
        "1.0",
        "--value-loss-weight",
        "0.3",
        "--val-split",
        "0.1",
        "--grad-clip",
        "1.0",
        "--save-top-k",
        "3"
      ]
    },
    {
      "name": "export_artifact",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/export_artifact.py",
        "--checkpoint",
        "{iter_dir}/checkpoint.npz",
        "--out-dir",
        "{iter_dir}",
        "--version",
        "{run_id}-iter{iteration}",
        "--model-type",
        "residual_v2",
        "--rules-version",
        "kalah_v1",
        "--input-encoding",
        "kalah_v3"
      ]
    },
    {
      "name": "rules_parity_fuzz",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/parity_fuzz.py",
        "--games",
        "20",
        "--seed",
        "42",
        "--max-moves",
        "120",
        "--out",
        "{iter_dir}/parity_report.json"
      ]
    },
    {
      "name": "arena_prefilter_report",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/arena.py",
        "--challenger",
        "{iter_dir}",
        "--current",
        "storage/ai/alphazero_lite/current",
        "--games",
        "30",
        "--challenger-simulations",
        "640",
        "--current-simulations",
        "256",
        "--workers",
        "6",
        "--out",
        "{iter_dir}/arena_prefilter_report.json",
        "--min-score",
        "0.55"
      ]
    },
    {
      "name": "arena_prefilter_validate",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/validate_arena_report.py",
        "--report",
        "{iter_dir}/arena_prefilter_report.json",
        "--min-score",
        "0.55",
        "--require-pass"
      ]
    },
    {
      "name": "arena_confirm_report",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/arena.py",
        "--challenger",
        "{iter_dir}",
        "--current",
        "storage/ai/alphazero_lite/current",
        "--games",
        "120",
        "--challenger-simulations",
        "640",
        "--current-simulations",
        "256",
        "--workers",
        "6",
        "--out",
        "{iter_dir}/arena_report.json",
        "--min-score",
        "0.55"
      ]
    },
    {
      "name": "mcts1200_baseline_report",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/mcts1200_baseline.py",
        "--challenger-path",
        "{iter_dir}",
        "--games",
        "30",
        "--seed",
        "42",
        "--az-base-simulations",
        "640",
        "--mcts-simulations",
        "1200",
        "--workers",
        "6",
        "--out",
        "{iter_dir}/mcts1200_report.json"
      ]
    },
    {
      "name": "current_mcts1200_baseline_report",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/mcts1200_baseline.py",
        "--challenger-path",
        "{current_path}",
        "--games",
        "30",
        "--seed",
        "42",
        "--az-base-simulations",
        "640",
        "--mcts-simulations",
        "1200",
        "--workers",
        "6",
        "--out",
        "{iter_dir}/current_mcts1200_report.json"
      ]
    },
    {
      "name": "benchmark_contract",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/benchmark.py",
        "--mode",
        "promotion",
        "--games",
        "60",
        "--seed",
        "42",
        "--challenger-path",
        "{iter_dir}",
        "--current-path",
        "storage/ai/alphazero_lite/current",
        "--arena-report",
        "{iter_dir}/arena_report.json",
        "--min-score",
        "0.55",
        "--mcts-report",
        "{iter_dir}/mcts1200_report.json",
        "--current-baseline-mcts-report",
        "{iter_dir}/current_mcts1200_report.json",
        "--out",
        "{iter_dir}/benchmark_report.json"
      ]
    },
    {
      "name": "arena_validate",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/validate_arena_report.py",
        "--report",
        "{iter_dir}/arena_report.json",
        "--min-score",
        "0.55"
      ]
    }
  ],
  "gates": {
    "rules_parity_report": "{iter_dir}/parity_report.json",
    "perspective_audit_report": "{iter_dir}/perspective_audit.json",
    "arena_report": "{iter_dir}/arena_report.json",
    "benchmark_report": "{iter_dir}/benchmark_report.json",
    "min_arena_score": 0.55,
    "max_runtime_parity_delta": 0.1
  }
}
