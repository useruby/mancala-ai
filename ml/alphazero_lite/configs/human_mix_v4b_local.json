{
  "run_id": "human-mix-v4b",
  "seed": 42,
  "iterations": 1,
  "start_iteration": 1,
  "replay_window": 1,
  "versions_dir": "/tmp/azlite_human_mix_v4b_versions",
  "current_path": "storage/ai/alphazero_lite/current",
  "steps": [
    {
      "name": "train",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/train.py",
        "--data-files",
        "tmp/runpod_results/aggressive-v3-clone-extend-iter2/aggressive-v3-clone-extend-iter2/self_play.jsonl,/tmp/human_games_sharpened.jsonl,ml/alphazero_lite/synthetic_pit4_fix.jsonl,ml/alphazero_lite/synthetic_midgame_regression_fix.jsonl",
        "--replay-weights",
        "1,4,200,80",
        "--init-checkpoint",
        "storage/ai/alphazero_lite/current/model.npz",
        "--out",
        "{iter_dir}/checkpoint.npz",
        "--epochs",
        "10",
        "--batch-size",
        "512",
        "--lr",
        "1e-3",
        "--device",
        "auto",
        "--hidden-sizes",
        "96,3",
        "--model-type",
        "residual_v3",
        "--input-encoding",
        "kalah_v3",
        "--value-loss",
        "huber",
        "--huber-delta",
        "1.0",
        "--value-loss-weight",
        "0.3",
        "--val-split",
        "0.1",
        "--grad-clip",
        "1.0",
        "--save-top-k",
        "3",
        "--policy-target-mode",
        "sharpened",
        "--value-target-mode",
        "sharpened"
      ]
    },
    {
      "name": "export_artifact",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/export_artifact.py",
        "--checkpoint",
        "{iter_dir}/checkpoint.npz",
        "--out-dir",
        "{iter_dir}",
        "--version",
        "{run_id}-iter{iteration}",
        "--model-type",
        "residual_v3",
        "--rules-version",
        "kalah_v1",
        "--input-encoding",
        "kalah_v3"
      ]
    },
    {
      "name": "arena_prefilter_report",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/arena.py",
        "--challenger",
        "{iter_dir}",
        "--current",
        "storage/ai/alphazero_lite/current",
        "--games",
        "30",
        "--challenger-simulations",
        "640",
        "--current-simulations",
        "256",
        "--workers",
        "6",
        "--out",
        "{iter_dir}/arena_prefilter_report.json",
        "--min-score",
        "0.55"
      ]
    }
  ]
}
