{
  "run_id": "aggressive-v3-superhuman",
  "seed": 42,
  "iterations": 1,
  "start_iteration": 2,
  "replay_window": 3,
  "versions_dir": "/tmp/azlite_v3_superhuman_versions",
  "current_path": "/tmp/azlite_v3_superhuman_versions/aggressive-v3-superhuman-iter1",
  "steps": [
    {
      "name": "self_play",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/self_play.py",
        "--out",
        "{iter_dir}/self_play.jsonl",
        "--games",
        "1000",
        "--workers",
        "6",
        "--seed",
        "42",
        "--seed-sweep",
        "41,42,43",
        "--simulations",
        "320",
        "--checkpoint",
        "{parent_checkpoint}",
        "--fpu-mode",
        "zero",
        "--root-policy-mode",
        "visit_count",
        "--tactical-root-bias",
        "0.0",
        "--temperature-threshold",
        "12",
        "--temperature",
        "1.1",
        "--temperature-late",
        "0.10",
        "--dirichlet-alpha",
        "0.3",
        "--dirichlet-epsilon",
        "0.3",
        "--schedule-progress-mode",
        "linear",
        "--iteration",
        "{iteration}",
        "--total-iterations",
        "2",
        "--tree-reuse-enabled",
        "--input-encoding",
        "kalah_v3",
        "--policy-target-mode",
        "sharpened",
        "--value-target-mode",
        "sharpened"
      ]
    },
    {
      "name": "perspective_audit",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/perspective_audit.py",
        "--data",
        "{iter_dir}/self_play.jsonl",
        "--out",
        "{iter_dir}/perspective_audit.json"
      ]
    },
    {
      "name": "mcts_bootstrap_dataset",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/generate_bootstrap_dataset.py",
        "--out",
        "{versions_dir}/{run_id}-iter1/mcts_bootstrap.jsonl",
        "--games",
        "1800",
        "--simulations",
        "3600",
        "--seed",
        "42",
        "--max-positions-per-game",
        "16",
        "--workers",
        "6",
        "--tree-reuse-enabled",
        "--input-encoding",
        "kalah_v3",
        "--policy-target-mode",
        "sharpened",
        "--value-target-mode",
        "sharpened"
      ]
    },
    {
      "name": "train",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/train.py",
        "--data-files",
        "{replay_data},{versions_dir}/{run_id}-iter1/mcts_bootstrap.jsonl",
        "--replay-weights",
        "{replay_weights},5",
        "--out",
        "{iter_dir}/checkpoint.npz",
        "--epochs",
        "14",
        "--batch-size",
        "512",
        "--device",
        "auto",
        "--hidden-sizes",
        "160,4",
        "--model-type",
        "residual_v3",
        "--input-encoding",
        "kalah_v3",
        "--value-loss",
        "huber",
        "--huber-delta",
        "1.0",
        "--value-loss-weight",
        "0.3",
        "--val-split",
        "0.1",
        "--grad-clip",
        "1.0",
        "--save-top-k",
        "4",
        "--policy-target-mode",
        "sharpened",
        "--value-target-mode",
        "sharpened"
      ]
    },
    {
      "name": "export_artifact",
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/export_artifact.py",
        "--checkpoint",
        "{iter_dir}/checkpoint.npz",
        "--out-dir",
        "{iter_dir}",
        "--version",
        "{run_id}-iter{iteration}",
        "--model-type",
        "residual_v3",
        "--rules-version",
        "kalah_v1",
        "--input-encoding",
        "kalah_v3"
      ]
    },
    {
      "name": "arena_prefilter_report",
      "skip_before_final_iteration": true,
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/arena.py",
        "--challenger",
        "{iter_dir}",
        "--current",
        "model-artifact/current",
        "--games",
        "30",
        "--challenger-simulations",
        "896",
        "--current-simulations",
        "256",
        "--workers",
        "6",
        "--fpu-mode",
        "zero",
        "--root-policy-mode",
        "deterministic",
        "--tactical-root-bias",
        "0.1",
        "--out",
        "{iter_dir}/arena_prefilter_report.json",
        "--min-score",
        "0.55"
      ]
    },
    {
      "name": "arena_prefilter_validate",
      "skip_before_final_iteration": true,
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/validate_arena_report.py",
        "--report",
        "{iter_dir}/arena_prefilter_report.json",
        "--min-score",
        "0.55",
        "--require-pass"
      ]
    },
    {
      "name": "arena_confirm_report",
      "skip_before_final_iteration": true,
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/arena.py",
        "--challenger",
        "{iter_dir}",
        "--current",
        "model-artifact/current",
        "--games",
        "120",
        "--challenger-simulations",
        "896",
        "--current-simulations",
        "256",
        "--workers",
        "6",
        "--fpu-mode",
        "zero",
        "--root-policy-mode",
        "deterministic",
        "--tactical-root-bias",
        "0.1",
        "--out",
        "{iter_dir}/arena_report.json",
        "--min-score",
        "0.55"
      ]
    },
    {
      "name": "arena_vs_hard_report",
      "skip_before_final_iteration": true,
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/arena.py",
        "--challenger",
        "{iter_dir}",
        "--current",
        "model-artifact/current",
        "--games",
        "120",
        "--challenger-simulations",
        "768",
        "--current-simulations",
        "256",
        "--workers",
        "6",
        "--fpu-mode",
        "zero",
        "--root-policy-mode",
        "deterministic",
        "--tactical-root-bias",
        "0.1",
        "--out",
        "{iter_dir}/arena_vs_hard_report.json",
        "--min-score",
        "0.55"
      ]
    },
    {
      "name": "mcts1200_baseline_report",
      "skip_before_final_iteration": true,
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/mcts1200_baseline.py",
        "--challenger-path",
        "{iter_dir}",
        "--games",
        "30",
        "--seed",
        "42",
        "--az-base-simulations",
        "896",
        "--mcts-simulations",
        "1200",
        "--workers",
        "6",
        "--fpu-mode",
        "zero",
        "--root-policy-mode",
        "deterministic",
        "--tactical-root-bias",
        "0.1",
        "--out",
        "{iter_dir}/mcts1200_report.json"
      ]
    },
    {
      "name": "current_mcts1200_baseline_report",
      "skip_before_final_iteration": true,
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/mcts1200_baseline.py",
        "--challenger-path",
        "model-artifact/current",
        "--games",
        "30",
        "--seed",
        "42",
        "--az-base-simulations",
        "896",
        "--mcts-simulations",
        "1200",
        "--workers",
        "6",
        "--fpu-mode",
        "zero",
        "--root-policy-mode",
        "deterministic",
        "--tactical-root-bias",
        "0.1",
        "--out",
        "{iter_dir}/current_mcts1200_report.json"
      ]
    },
    {
      "name": "benchmark_contract",
      "skip_before_final_iteration": true,
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/benchmark.py",
        "--mode",
        "promotion",
        "--games",
        "80",
        "--seed",
        "42",
        "--challenger-path",
        "{iter_dir}",
        "--current-path",
        "model-artifact/current",
        "--arena-report",
        "{iter_dir}/arena_report.json",
        "--min-score",
        "0.55",
        "--mcts-report",
        "{iter_dir}/mcts1200_report.json",
        "--current-baseline-mcts-report",
        "{iter_dir}/current_mcts1200_report.json",
        "--out",
        "{iter_dir}/benchmark_report.json"
      ]
    },
    {
      "name": "arena_validate",
      "skip_before_final_iteration": true,
      "command": [
        ".venv/bin/python",
        "ml/alphazero_lite/validate_arena_report.py",
        "--report",
        "{iter_dir}/arena_report.json",
        "--min-score",
        "0.55"
      ]
    }
  ]
}
